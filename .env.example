# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Neo4j Aura ───────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=your-instance-id
AURA_INSTANCENAME=My instance

# ── AMD MI300X / ROCm (vLLM) ─────────────────────────────────────────────────
# SSH into your AMD Developer Cloud VM and run:
#   pip install vllm
#   vllm serve Qwen/Qwen2.5-72B-Instruct-AWQ --port 8000 --dtype float16
VLLM_BASE_URL=http://<AMD_VM_IP>:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# AMD Developer Cloud VM
AMD_VM_IP=<YOUR_AMD_VM_PUBLIC_IP>
AMD_VM_USER=root
# AMD_VM_SSH_KEY=~/.ssh/amd_hackathon.pem

# ── LLM Fallback ─────────────────────────────────────────────────────────────
FALLBACK_API_KEY=your-fallback-api-key
FALLBACK_BASE_URL=https://ai.aimlapi.com/v1
FALLBACK_MODEL=claude-opus-4-7

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── DRL checkpoint ───────────────────────────────────────────────────────────
DRL_CHECKPOINT_PATH=backend/drl/checkpoints/ea_policy_v1.pt

# ── Jira Integration ─────────────────────────────────────────────────────────
# https://id.atlassian.com/manage-profile/security/api-tokens → Create API token
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=user@yourorg.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=EAOPT

# ── Web enrichment (optional) ────────────────────────────────────────────────
TAVILY_API_KEY=
SCRAPING_PROXY=
