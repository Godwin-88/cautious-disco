ity_ids: ['fc970d471fdf326b5edbc5c8', '63c16f23f3c59f90ddf23552', '65109c60d4670dd6a0acb97b', '18121d4c892ebc7486596ccb', '44943e3a43e9428bad299339', 'd857a2c4544fcc10e5e20921', '6efc5f27180659a17ff65183', '8c2a4182c7c0c00cdba67de6', '204217b2a3c92f9e4d795bc1', 'be1cbd7489e87794734f1d38', '4377d1af12e88e0ce7d463b8', '3e5f0d38baad0b1905f72a74', '3e493e9e24c77692b328c326', 'f3ad5c4a2672d0d31f830e6d', '8389a11387c775dc0025178d', '5839fd171b12bdda9d77b680', '78cedcbd244798623f2d6a8d', 'e161ff31bc1482c68b845eb8', 'a9431591cc68e15e2a4ade44', '694ea19c506c0fa6f020d0fa', '1b4321d0cf1b029490e0c76f', 'a8786188c690be503155bac1', 'c58fe53d47c68fd069d20763', '95ec906624bafa8ab4d740c5', 'e0ab845c0da90ab525f0c251', '4ee1d5d18113efa9fa983f99', '8bc0409d66c079ad04b4dcb0', '07d6a92d15b6d07f2cbb2801', '2a5b3d7976ee175ccb4d699d', 'd386255b098cefc13cdb70a8', '33854427a15ac5f52a0a2efb', 'c5b06d472486c258183f712c', 'c79f868cb0685f1d604d1270', 'b160a2b9a8f2bef408b5ccb6', 'a457853cdf52d5cc8a16313b', 'bb57a90c29d166f63a77db91'], _import_id: 6654};
MERGE (n:GeneratedOutput {_import_id: 6655}) SET n += {phases_count: 3, cache_key: '8b031be0741f73e3', org_type: 'Airport Authority', created_at: '2026-05-09T13:26:21.698000000+00:00', hit_count: 0, epics_count: 20, output_json: '{"request_id":"0a404b22-89e0-41b3-b11f-3af25590d24c","org_type":"Airport Authority","phases":[{"phase_number":1,"phase_name":"Foundation & Quick Wins","duration_months":6,"epics":[{"epic_id":"EPIC-8E395753","title":"Manage Emergency Response","subdomain_group":"Manage Aviation Operation Services","description":"Capability to plan, coordinate, and execute emergency response activities across airport operations, ensuring rapid reaction to incidents including acts of unlawful interference, safety events, and security breaches. Operates within the Manage Aviation Operation Services subdomain under Manage Airport Core Operation.","business_value":"Reduce average emergency response time by 25% through AI-assisted decision support, and achieve 100% regulatory compliance with ICAO Annex 17 reporting obligations to minimise operational disruption and reputational risk.","strategic_rationale":"Per Gartner Top Trends 2025, enterprises adopting AI-Powered Digital Transformation report 20-30% productivity gains and 15% cost reduction on average, justifying investment in agentic workflows and generative AI to augment emergency response coordination.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["AI recommendations may be over-trusted by operators leading to procedural non-compliance if human-in-the-loop controls are weak","Integration delays with legacy screening and access control systems could jeopardise the 12-week delivery window and ICAO compliance posture"],"estimated_sprints":6,"features":[{"title":"Emergency Response Command & Coordination","description":"Centralised AI-enabled command platform to orchestrate emergency response across security, safety, and operational teams.","technical_notes":"Leverages Generative AI and Agentic workflows for incident triage, Vector databases for rapid retrieval of SOPs, and AMD MI300X inference for low-latency decision support.","user_stories":[{"role":"Emergency Operations Controller","want":"an AI-assisted command console that consolidates incident feeds and recommends response playbooks","so_that":"I can coordinate multi-agency response within target activation timeframes","acceptance_criteria":["Console ingests CCTV, access control, and radio alerts in real time","Agentic workflow recommends top-3 playbooks with confidence scores","All actions are logged to an immutable audit trail"],"tasks":[{"title":"Design command console architecture","description":"Produce solution architecture aligned with TOGAF ADM Phase C covering data, application, and integration layers.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build agentic playbook recommender","description":"Implement generative AI agent using vector database of historical incidents and SOPs to recommend playbooks.","estimated_days":8,"assignee_role":"AI/ML Engineer"},{"title":"Integrate incident feed pipelines","description":"Develop streaming data pipelines connecting CCTV analytics, access control, and radio dispatch systems.","estimated_days":7,"assignee_role":"Data Engineer"}]}],"estimated_story_points":13},{"title":"Unlawful Interference Reporting","description":"Automated workflow to capture, classify, and report acts of unlawful interference to authorities within ICAO mandated timelines.","technical_notes":"Uses Generative AI to draft regulatory reports and Agentic workflows to route approvals; evidence indexed in Vector databases.","user_stories":[{"role":"Aviation Security Compliance Officer","want":"an automated reporting workflow for acts of unlawful interference","so_that":"reports are submitted to regulators within 24 hours with full evidence chain","acceptance_criteria":["Draft report auto-generated within 2 hours of incident classification","Dual approval workflow enforced before submission","Submission timestamp and acknowledgement captured"],"tasks":[{"title":"Configure incident classification model","description":"Train and deploy classifier aligned to ICAO Annex 17 taxonomy of unlawful interference acts.","estimated_days":6,"assignee_role":"Data Scientist"},{"title":"Build regulator submission connector","description":"Develop secure API integration with national regulator portal including retry and audit logging.","estimated_days":5,"assignee_role":"Integration Engineer"},{"title":"Implement approval workflow","description":"Configure dual-approval BPMN workflow with SLA monitoring for the 24-hour reporting window.","estimated_days":4,"assignee_role":"Business Process Analyst"}]}],"estimated_story_points":8},{"title":"Security Quality Control & Inspection","description":"Digital inspection and quality assurance capability for continuous monitoring of security measures effectiveness.","technical_notes":"Generative AI summarises inspection findings; Vector databases support similarity search across historical non-conformities.","user_stories":[{"role":"Security Quality Inspector","want":"a mobile-enabled inspection tool with AI-driven finding analysis","so_that":"I can identify recurring non-conformities and improve security posture","acceptance_criteria":["Inspections captured on mobile with offline support","AI highlights recurring findings across 12-month window","Corrective actions tracked to closure with SLA alerts"],"tasks":[{"title":"Develop mobile inspection app","description":"Build cross-platform inspection app with offline sync conforming to airport enterprise mobility standards.","estimated_days":8,"assignee_role":"Mobile Developer"},{"title":"Index findings to vector database","description":"Implement embedding pipeline and vector search for similarity analysis of inspection findings.","estimated_days":5,"assignee_role":"Data Engineer"},{"title":"Configure corrective action tracker","description":"Set up CAPA workflow with SLA monitoring aligned to security management system requirements.","estimated_days":3,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Access Control & Screening Assurance","description":"Capability to assure integrity of passenger and baggage screening and access control to security restricted areas.","technical_notes":"AMD MI300X inference for real-time anomaly detection on screening imagery; Agentic workflows for alert triage.","user_stories":[{"role":"Screening Operations Supervisor","want":"real-time anomaly detection across screening lanes and access points","so_that":"breaches are detected and contained before escalation","acceptance_criteria":["Anomaly detection latency under 2 seconds per event","Integration with all approved screening equipment","Access control breaches auto-escalated to emergency console"],"tasks":[{"title":"Deploy inference platform","description":"Provision AMD MI300X-based inference cluster with high-availability and DR per enterprise reference architecture.","estimated_days":7,"assignee_role":"Infrastructure Engineer"},{"title":"Integrate screening equipment","description":"Build adapters to approved screening equipment exposing standardised telemetry to the assurance platform.","estimated_days":8,"assignee_role":"Integration Engineer"},{"title":"Implement breach escalation flow","description":"Configure agentic workflow to route access control breaches to the emergency command console with context.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Mean emergency response activation time reduced to under 3 minutes measured across 95% of drills","Phase exit: end-to-end emergency response platform validated via full-scale exercise with sign-off from Airport Operations Director and Security Regulator"],"phase":1},{"epic_id":"EPIC-1251F79A","title":"Manage Air Traffic Control","subdomain_group":"Manage Aviation Operation Services","description":"Capability to orchestrate safe, efficient, and compliant air traffic control operations across airport airspace, integrating surveillance, communication, and decision-support systems. Scoped within Manage Aviation Operation Services under Manage Airport Core Operation, covering ATC tower operations, approach control, and coordination with national aviation authorities.","business_value":"Reduce runway incursions and ATC-related delays by 25%, and improve airspace throughput and controller productivity by 20% through AI-augmented decision support.","strategic_rationale":"Per Gartner Top Trends 2025 (AI-Powered Digital Transformation), enterprises deploying AI report 20-30% productivity gains and 15% cost reduction on average, directly applicable to ATC workload optimisation and predictive conflict detection.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["AI model hallucination or false conflict alerts eroding controller trust and safety posture","Non-compliance with ICAO Annex 17 reporting timelines due to integration gaps between ATC and security systems"],"estimated_sprints":6,"features":[{"title":"Airspace Surveillance & Conflict Detection","description":"AI-enabled surveillance platform providing real-time aircraft tracking and predictive conflict alerts to controllers.","technical_notes":"Leverages Generative AI and Agentic workflows on AMD MI300X inference accelerators, with Vector databases storing historical trajectory embeddings for similarity-based conflict prediction.","user_stories":[{"role":"Air Traffic Controller","want":"real-time AI-assisted conflict detection overlays on the radar display","so_that":"I can proactively resolve potential separation losses and improve safety margins","acceptance_criteria":["Conflict alerts generated ≥90 seconds before predicted loss of separation","False positive rate below 5% during validation testing","Alerts integrated into existing CWP (Controller Working Position) without workflow disruption"],"tasks":[{"title":"Design conflict detection AI model architecture","description":"Define generative AI model and agentic workflow for trajectory prediction aligned to ICAO SARPs.","estimated_days":6,"assignee_role":"Solutions Architect"},{"title":"Deploy MI300X inference cluster","description":"Provision AMD MI300X GPU inference nodes and integrate with surveillance data bus.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Validate alert accuracy with historical data","description":"Replay 12 months of track data to measure precision, recall, and latency against KPIs.","estimated_days":5,"assignee_role":"Data Analyst"}]}],"estimated_story_points":13},{"title":"ATC Security & Access Control Integration","description":"Integrates ATC operational areas with airport-wide security restricted area access control and NASP compliance reporting.","technical_notes":"Agentic workflows automate security event triage and incident reporting, with Vector databases indexing threat intelligence for rapid retrieval.","user_stories":[{"role":"Aviation Security Officer","want":"automated unlawful interference reporting with 24-hour regulatory submission","so_that":"the Authority maintains continuous ICAO Annex 17 compliance","acceptance_criteria":["Incident reports auto-generated and submitted to national authority within 24 hours","Access control logs for ATC tower retained for minimum 2 years","Quarterly quality control inspection reports produced automatically"],"tasks":[{"title":"Implement NASP reporting workflow","description":"Build agentic workflow aligned to ICAO Annex 17 reporting templates and timelines.","estimated_days":7,"assignee_role":"Security Analyst"},{"title":"Integrate ATC tower access control","description":"Connect biometric and RFID access systems to centralised identity platform with audit logging.","estimated_days":6,"assignee_role":"Solutions Architect"},{"title":"Configure quality control inspection dashboard","description":"Develop dashboard to track inspection schedules, findings, and remediation against NASP.","estimated_days":4,"assignee_role":"Data Analyst"}]}],"estimated_story_points":8},{"title":"Controller Decision Support & Training","description":"Generative AI copilot providing controllers with procedural guidance, weather impact analysis, and training simulation.","technical_notes":"Generative AI models fine-tuned on ICAO procedures and local SOPs, served via MI300X inference and grounded through Vector databases of historical ATC transcripts.","user_stories":[{"role":"ATC Supervisor","want":"an AI copilot that surfaces SOP guidance and weather advisories contextually","so_that":"controllers make faster, compliant decisions during high-workload periods","acceptance_criteria":["Copilot responses grounded in approved SOPs with citation links","Median response latency under 2 seconds","Controller productivity improvement of ≥20% measured via handled-movements-per-hour"],"tasks":[{"title":"Build SOP knowledge vector index","description":"Ingest ICAO and local ATC SOPs into vector database with semantic chunking.","estimated_days":5,"assignee_role":"Data Engineer"},{"title":"Develop generative AI copilot UI","description":"Integrate copilot panel into CWP with citation rendering and feedback capture.","estimated_days":7,"assignee_role":"Solutions Architect"},{"title":"Conduct controller UAT and training","description":"Run user acceptance testing and structured training sessions with ATC staff.","estimated_days":4,"assignee_role":"Business Analyst"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥99.95% ATC system availability and <2s latency on surveillance data feeds","Phase exit: All ICAO Annex 17 controls validated by independent audit and signed off by CISO and Head of ATC"],"phase":1},{"epic_id":"EPIC-E3249BE1","title":"Manage Aircraft Repair","subdomain_group":"Manage Aviation Handling Services","description":"Capability to oversee aircraft maintenance, repair, and overhaul (MRO) activities ensuring airworthiness, regulatory compliance, and operational readiness across the airport\'s aviation handling services. Scope covers defect management, scheduled and unscheduled repairs, parts logistics, and certification within the Manage Aviation Handling Services subdomain.","business_value":"Reduced aircraft-on-ground (AOG) time by 25% through predictive maintenance and increased repair turnaround efficiency improving on-time departure performance.","strategic_rationale":"Per Gartner Top Trends 2025, enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, positioning AI-powered digital transformation as the key enabler for aircraft repair operations.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Regulatory non-compliance with ICAO Annex 17 leading to operational sanctions and reputational damage","AI model inaccuracy in defect classification or parts forecasting causing extended AOG and safety exposure"],"estimated_sprints":6,"features":[{"title":"Aircraft Defect Reporting & Triage","description":"Digital capture, classification, and triage of aircraft defects raised by flight crew and ground handling teams.","technical_notes":"Leverage Generative AI and Agentic workflows to auto-classify defect narratives; vector databases index historical defect corpora for similarity matching.","user_stories":[{"role":"Line Maintenance Engineer","want":"to log and auto-classify aircraft defects via a mobile workflow","so_that":"defects are triaged quickly and routed to the correct repair team","acceptance_criteria":["Defects logged on mobile sync to MRO system within 30 seconds","AI classifier assigns ATA chapter with ≥90% accuracy","Access control enforced to security restricted areas during data entry"],"tasks":[{"title":"Design defect intake data model","description":"Define canonical defect schema aligned to ATA 100 chapters and ICAO reporting fields.","estimated_days":3,"assignee_role":"Solutions Architect"},{"title":"Build GenAI defect classifier","description":"Train and deploy LLM-based classifier using vector database of historical defect records.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Implement mobile capture UI","description":"Develop offline-capable mobile interface for engineers to log defects on the ramp.","estimated_days":6,"assignee_role":"Full-Stack Developer"}]}],"estimated_story_points":8},{"title":"Repair Scheduling & Resource Orchestration","description":"Optimise allocation of hangar slots, engineers, tooling, and parts to minimise AOG time.","technical_notes":"Agentic workflows orchestrate scheduling agents; AMD MI300X inference accelerates optimisation models for near-real-time replanning.","user_stories":[{"role":"MRO Planner","want":"an AI-driven scheduler that optimises repair tasks across hangars and crews","so_that":"aircraft return to service faster with balanced resource utilisation","acceptance_criteria":["Scheduler produces feasible plan within 2 minutes for 50 concurrent tasks","Quality control inspections of security measures are scheduled automatically","Plan respects crew certifications and duty-time limits"],"tasks":[{"title":"Develop optimisation engine","description":"Implement constraint-based solver for hangar, crew, and parts allocation.","estimated_days":9,"assignee_role":"Operations Research Engineer"},{"title":"Integrate agentic orchestration layer","description":"Wire scheduling agents to MRO, HR, and parts systems via event bus.","estimated_days":7,"assignee_role":"Integration Engineer"}]}],"estimated_story_points":13},{"title":"Parts & Inventory Management","description":"Manage spare parts forecasting, procurement, and traceability for repair activities.","technical_notes":"Generative AI forecasts demand; vector databases support semantic part search across multilingual catalogues.","user_stories":[{"role":"Parts Inventory Controller","want":"AI-based forecasting of critical spare parts demand","so_that":"stock-outs are prevented and AOG risk is reduced","acceptance_criteria":["Forecast MAPE ≤15% for top 100 SKUs","All inbound parts screened using approved equipment before entering airside store","Full traceability from PO to aircraft tail number"],"tasks":[{"title":"Build demand forecasting model","description":"Develop and validate ML forecasting model for consumable and rotable parts.","estimated_days":8,"assignee_role":"Data Scientist"},{"title":"Implement parts traceability ledger","description":"Configure serialised tracking with immutable audit trail for regulated components.","estimated_days":6,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8},{"title":"Compliance, Certification & Security Reporting","description":"Ensure repair activities comply with ICAO, national regulator, and airport security mandates with automated evidence capture.","technical_notes":"Agentic workflows auto-compile audit packs; GenAI drafts incident narratives for regulator submission.","user_stories":[{"role":"Compliance & Security Officer","want":"automated reporting of unlawful interference and security quality checks tied to repair operations","so_that":"the organisation meets ICAO Annex 17 obligations on time","acceptance_criteria":["Implement national aviation security programme (NASP) controls within repair workflows","Report all acts of unlawful interference within 24 hours via automated pipeline","Audit evidence retrievable within 5 minutes for any repair job"],"tasks":[{"title":"Configure NASP control mappings","description":"Map NASP controls to repair process steps and enforce via workflow gates.","estimated_days":5,"assignee_role":"Security Analyst"},{"title":"Automate 24-hour incident reporting","description":"Build workflow that generates and submits regulator-formatted incident reports within SLA.","estimated_days":6,"assignee_role":"Compliance Engineer"},{"title":"Implement audit evidence vault","description":"Centralise certifications, sign-offs, and inspection records with tamper-evident storage.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":13}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥95% repair turnaround SLA compliance and ≤2% rework rate measured monthly","Phase exit: end-to-end repair workflow operational in production with signed-off UAT and regulator acceptance"],"phase":1},{"epic_id":"EPIC-32FB9653","title":"Manage Asset Development","subdomain_group":"Manage Infrastructure Asset Lifecyle","description":"Manage Asset Development capability governs the planning, acquisition, commissioning, and lifecycle evolution of airport infrastructure assets to ensure operational readiness and regulatory compliance. Scope covers the Manage Infrastructure Asset Lifecycle subdomain within Manage Airport Core Operations, aligning asset investments with aviation security and operational continuity mandates.","business_value":"Accelerated asset commissioning cycles reducing time-to-operational-readiness by 25%, and improved asset utilization delivering measurable cost reduction and service availability gains across terminal and airside infrastructure.","strategic_rationale":"Per Gartner Top Trends 2025 (AI-Powered Digital Transformation), enterprises adopting AI report 20-30% productivity gains and 15% cost reduction on average, justifying AI-enabled asset lifecycle automation as a strategic priority for the Airport Authority.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 mandatory controls leading to regulatory sanction and loss of operating authorisation","AI model hallucination or inference latency degrading asset monitoring reliability and delaying 24-hour unlawful interference reporting"],"estimated_sprints":6,"features":[{"title":"Asset Planning & Demand Forecasting","description":"AI-assisted forecasting of infrastructure asset demand aligned to passenger and cargo growth projections.","technical_notes":"Generative AI for scenario modelling and Vector databases for historical asset performance similarity search.","user_stories":[{"role":"Capital Planning Analyst","want":"to generate AI-driven asset demand forecasts by terminal zone","so_that":"capital investment decisions align with traffic growth and security mandates","acceptance_criteria":["Forecast model covers 5-year horizon with ≥85% accuracy on back-test","Scenarios include ICAO Annex 17 security-restricted area expansion","Outputs exportable to capital planning workbench"],"tasks":[{"title":"Build demand forecasting model","description":"Develop generative AI forecasting model using historical throughput and capital project data.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Integrate forecast to planning tool","description":"Wire model outputs into the capital planning workbench via API.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8},{"title":"Asset Acquisition & Commissioning","description":"Streamlined procurement, installation, and commissioning of infrastructure assets with embedded security screening compliance.","technical_notes":"Agentic workflows for procurement orchestration and approval routing across stakeholders.","user_stories":[{"role":"Asset Commissioning Manager","want":"an agentic workflow to orchestrate asset commissioning checklists","so_that":"new assets enter service with full ICAO Annex 17 compliance verification","acceptance_criteria":["Workflow enforces access control validation for security restricted areas","Screening equipment commissioning gates cannot be bypassed","Commissioning evidence pack auto-generated"],"tasks":[{"title":"Design commissioning workflow","description":"Model agentic workflow states, gates, and compliance checkpoints for asset commissioning.","estimated_days":6,"assignee_role":"Solutions Architect"},{"title":"Implement security gate controls","description":"Embed ICAO Annex 17 access-control and screening verification gates into the workflow engine.","estimated_days":7,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Asset Operations & Monitoring","description":"Real-time asset health monitoring and quality-control inspection tracking across the airport estate.","technical_notes":"AMD MI300X inference for low-latency anomaly detection on telemetry streams.","user_stories":[{"role":"Operations Control Supervisor","want":"real-time anomaly alerts on critical asset telemetry","so_that":"quality control inspections and unlawful interference reporting occur within mandated timeframes","acceptance_criteria":["Anomaly alerts delivered within 60 seconds of telemetry event","Unlawful interference incidents auto-trigger 24-hour reporting workflow","Inspection logs retained for audit"],"tasks":[{"title":"Deploy inference anomaly model","description":"Deploy anomaly detection model on AMD MI300X inference infrastructure for telemetry streams.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Configure 24-hour reporting workflow","description":"Automate unlawful interference reporting pipeline meeting ICAO Annex 17 24-hour SLA.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Asset Decommissioning & Disposal","description":"Controlled retirement of infrastructure assets with data sanitisation and regulatory closeout.","technical_notes":"Vector databases for retained asset provenance records and Generative AI for disposal documentation drafting.","user_stories":[{"role":"Asset Lifecycle Officer","want":"an automated decommissioning record with AI-drafted closeout reports","so_that":"retired assets are disposed securely and audit evidence is preserved","acceptance_criteria":["Closeout report generated within 2 business days of decommission trigger","Access control revocation confirmed for retired security zones","Provenance record stored in vector index"],"tasks":[{"title":"Build disposal documentation generator","description":"Implement generative AI service producing standardised decommissioning closeout reports.","estimated_days":5,"assignee_role":"Data Engineer"},{"title":"Integrate access control revocation","description":"Connect decommissioning workflow to IAM to revoke security restricted area privileges.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":5}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥95% asset lifecycle data completeness and ≥20% productivity gain on asset onboarding measured at phase exit","Phase exit: all sub-capabilities delivered, UAT signed off, ICAO Annex 17 compliance evidence lodged in audit register"],"phase":1},{"epic_id":"EPIC-43407308","title":"Manage Safety & Security","subdomain_group":"Manage Aviation Operation Services","description":"Capability to manage aviation safety and security operations across the airport, ensuring compliance with international aviation security standards and protection against acts of unlawful interference. Scope covers aviation operation services within the airport core operations domain, including passenger screening, access control, security programme governance, and incident reporting.","business_value":"Achieve 100% compliance with ICAO Annex 17 aviation security requirements and reduce security incident response time by 40% through AI-augmented detection and workflow automation.","strategic_rationale":"Per Gartner Top Trends 2025, enterprises adopting AI-powered digital transformation report 20-30% productivity gains and 15% cost reduction on average, directly applicable to security screening throughput, quality inspections, and incident triage at the Airport Authority.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Integration complexity with legacy screening and access control systems may delay go-live and impact ICAO compliance deadlines","AI threat detection model bias or drift could increase false negatives, creating regulatory and safety exposure"],"estimated_sprints":6,"features":[{"title":"National Aviation Security Programme (NASP) Governance","description":"Establish and digitise the NASP governance framework, policies, and control library aligned to ICAO Annex 17.","technical_notes":"Generative AI assistants for policy drafting and gap analysis; Vector databases to index regulatory clauses, SOPs, and audit evidence for semantic retrieval.","user_stories":[{"role":"Aviation Security Manager","want":"a digitised NASP policy and control library with AI-assisted gap analysis","so_that":"the airport maintains continuous alignment with ICAO Annex 17 and national regulator expectations","acceptance_criteria":["NASP document set published and version-controlled in the GRC platform","AI-generated gap analysis maps every ICAO Annex 17 clause to an internal control","Annual NASP review workflow automated with approval evidence captured"],"tasks":[{"title":"Draft NASP policy framework","description":"Author the NASP policy, scope, roles, and responsibilities aligned with ICAO Annex 17 Ed. 11.","estimated_days":6,"assignee_role":"Security Analyst"},{"title":"Deploy vector-indexed control library","description":"Ingest regulations and SOPs into a vector database to enable semantic retrieval and AI gap analysis.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8},{"title":"Passenger & Baggage Screening Operations","description":"Operate approved screening lanes with AI-assisted threat detection for passengers and carry-on baggage.","technical_notes":"Agentic workflows to orchestrate screening exceptions; AMD MI300X inference for real-time image threat detection on X-ray and CT scanners.","user_stories":[{"role":"Screening Supervisor","want":"AI-assisted image analysis integrated with approved screening equipment","so_that":"every passenger and carry-on bag is screened accurately with minimal false alarms","acceptance_criteria":["All lanes integrated with approved ECAC/TSA-listed equipment","AI threat detection model achieves ≥95% recall on validation dataset","Screening exception workflow resolves alerts within SLA"],"tasks":[{"title":"Integrate screening equipment telemetry","description":"Stream X-ray/CT images and lane events into central platform for inference and audit.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Deploy MI300X inference service","description":"Host threat detection models on AMD MI300X accelerators with latency under 300ms per bag.","estimated_days":8,"assignee_role":"Solutions Architect"},{"title":"Configure agentic exception workflow","description":"Automate secondary screening dispatch, supervisor review, and evidence capture.","estimated_days":5,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Access Control for Security Restricted Areas","description":"Enforce identity, authorisation, and biometric access control across all security restricted areas (SRAs).","technical_notes":"Agentic workflows for access request approvals; Vector databases for behavioural anomaly profiling of badge usage.","user_stories":[{"role":"Access Control Administrator","want":"role-based badge provisioning with biometric verification and anomaly detection","so_that":"only authorised personnel enter security restricted areas","acceptance_criteria":["All SRA doors enforce multi-factor (badge + biometric) authentication","Access rights recertified quarterly with documented evidence","Anomalous badge usage generates alert within 60 seconds"],"tasks":[{"title":"Configure RBAC and recertification","description":"Define SRA access roles and automate quarterly recertification campaigns.","estimated_days":5,"assignee_role":"Security Analyst"},{"title":"Implement anomaly detection on access logs","description":"Use vector-based behavioural profiling to flag abnormal badge patterns in real time.","estimated_days":6,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8},{"title":"Security Quality Control & Assurance","description":"Plan and execute quality control inspections, covert tests, and audits of all security measures.","technical_notes":"Generative AI to draft inspection plans and findings reports; Agentic workflows to schedule, evidence, and track corrective actions.","user_stories":[{"role":"Quality Control Inspector","want":"a digital inspection and corrective action platform","so_that":"security measure effectiveness is continuously verified and improved","acceptance_criteria":["Annual QC inspection plan approved and executed to ≥95% completion","All findings tracked to closure with root-cause analysis","AI-generated inspection reports reviewed and signed off digitally"],"tasks":[{"title":"Build inspection scheduling workflow","description":"Implement agentic scheduling and evidence capture for routine and covert inspections.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Deploy AI report generator","description":"Configure generative AI templates for inspection reports with reviewer-in-the-loop approval.","estimated_days":4,"assignee_role":"Data Engineer"}]}],"estimated_story_points":5},{"title":"Unlawful Interference Incident Reporting","description":"Detect, triage, and report acts of unlawful interference to the national regulator within 24 hours.","technical_notes":"Agentic workflows for incident intake, classification, and regulator notification; Generative AI for draft incident narratives.","user_stories":[{"role":"Security Operations Centre Lead","want":"an incident reporting workflow that guarantees 24-hour regulator notification","so_that":"the Airport Authority meets ICAO Annex 17 reporting obligations","acceptance_criteria":["Incident intake captures classification, evidence, and witnesses","Regulator notification dispatched within 24 hours in 100% of cases","Post-incident review completed within 10 business days"],"tasks":[{"title":"Configure incident classification engine","description":"Define taxonomy for unlawful interference and automate routing rules.","estimated_days":4,"assignee_role":"Security Analyst"},{"title":"Automate regulator notification","description":"Implement agentic workflow with SLA timers and AI-drafted notification templates.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥99.5% screening equipment availability and <5 min average passenger screening wait time measured over 30 consecutive operational days","Phase exit: ICAO Annex 17 compliance audit completed with zero critical findings and signed off by Accountable Security Manager"],"phase":1},{"epic_id":"EPIC-D24D6D9E","title":"Manage Aircraft Maintenance","subdomain_group":"Manage Aviation Handling Services","description":"Capability to plan, execute, monitor and govern aircraft maintenance activities ensuring airworthiness, safety and regulatory compliance across all fleet operations at the airport. Scoped within Manage Airport Core Operation > Manage Aviation Handling Services to support secure, efficient and timely turnaround of aircraft.","business_value":"Reduce aircraft downtime and unscheduled maintenance events by 25%, and improve maintenance labour productivity by 20% through AI-assisted diagnostics and predictive scheduling.","strategic_rationale":"Aligns with Gartner Top Trends 2025 (AI-Powered Digital Transformation), which reports that enterprises using AI achieve 20-30% productivity gains and 15% cost reduction on average.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["AI model drift leading to missed predictive maintenance events and potential airworthiness exposure","Integration complexity between legacy MRO systems and new agentic workflows delaying the 12-week delivery window"],"estimated_sprints":6,"features":[{"title":"Predictive Maintenance Planning","description":"AI-driven forecasting of component failures and scheduling of preventive maintenance windows for aircraft.","technical_notes":"Built on Generative AI models and Vector databases for similarity search across historical maintenance logs, deployed on AMD MI300X inference infrastructure.","user_stories":[{"role":"Maintenance Planner","want":"AI-generated predictive maintenance schedules based on aircraft telemetry and historical failures","so_that":"unscheduled downtime is reduced and aircraft availability is maximised","acceptance_criteria":["Model predicts component failure with ≥85% precision on validation dataset","Schedules automatically integrate with existing MRO workflow","Security restricted area access logs are honoured in task assignment"],"tasks":[{"title":"Ingest aircraft telemetry into vector DB","description":"Build data pipeline to stream sensor and maintenance logs into the vector database for similarity search.","estimated_days":6,"assignee_role":"Data Engineer"},{"title":"Train predictive failure model","description":"Train and validate generative AI model on historical maintenance data using AMD MI300X inference cluster.","estimated_days":8,"assignee_role":"ML Engineer"},{"title":"Integrate schedule API with MRO system","description":"Expose predictive schedule outputs via API to the maintenance execution platform.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8},{"title":"Maintenance Execution & Work Order Management","description":"Digital work order management with agentic workflows that assign, track and close aircraft maintenance tasks.","technical_notes":"Leverages Agentic workflows to orchestrate technician assignment, parts procurement and compliance checks end-to-end.","user_stories":[{"role":"Line Maintenance Engineer","want":"a mobile work order interface with agentic task guidance","so_that":"I can execute maintenance faster and capture compliance evidence in real time","acceptance_criteria":["Work orders digitally signed and timestamped","Access to security restricted areas validated per technician credential","All unlawful interference events reported within 24 hours via integrated reporting workflow"],"tasks":[{"title":"Design digital work order schema","description":"Define data model and state machine for work orders covering creation, assignment, execution and closure.","estimated_days":4,"assignee_role":"Solutions Architect"},{"title":"Implement agentic task orchestration","description":"Develop agentic workflow engine to route, escalate and close work orders with minimal human intervention.","estimated_days":9,"assignee_role":"Software Engineer"},{"title":"Configure access control integration","description":"Integrate with airport IAM to enforce ICAO Annex 17 restricted area access during task assignment.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Maintenance Quality Assurance & Compliance","description":"Automated quality control inspections and compliance reporting against ICAO Annex 17 and airworthiness regulations.","technical_notes":"Uses Generative AI to summarise inspection findings and Vector databases to retrieve similar historical non-conformances.","user_stories":[{"role":"Quality Assurance Inspector","want":"automated evidence collection and AI-summarised inspection reports","so_that":"quality control inspections are consistent and compliance reporting is timely","acceptance_criteria":["Quality control inspections of security measures conducted and logged at defined cadence","Inspection reports generated within 1 hour of completion","Non-conformance trends visible on compliance dashboard"],"tasks":[{"title":"Build compliance evidence repository","description":"Create a tamper-evident repository aligned to ICAO Annex 17 audit requirements.","estimated_days":5,"assignee_role":"Data Engineer"},{"title":"Develop AI inspection summariser","description":"Implement generative AI summarisation of inspection findings with human-in-the-loop review.","estimated_days":7,"assignee_role":"ML Engineer"},{"title":"Build compliance reporting dashboard","description":"Deliver Power BI dashboard tracking KPIs, unlawful interference reports and NASP compliance status.","estimated_days":4,"assignee_role":"BI Developer"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥95% on-time maintenance task completion measured monthly over the 12-week pilot","Phase exit: all features deployed to production with signed-off UAT, security sign-off and ICAO Annex 17 compliance evidence logged"],"phase":1}],"objectives":["Reduce average emergency response time by 25% through AI-assisted decision support, and achieve 100% regulatory compliance with ICAO Annex 17 reporting obligations to minimise operational disruption and reputational risk.","Reduce runway incursions and ATC-related delays by 25%, and improve airspace throughput and controller productivity by 20% through AI-augmented decision support.","Reduced aircraft-on-ground (AOG) time by 25% through predictive maintenance and increased repair turnaround efficiency improving on-time departure performance."],"key_milestones":["Manage Emergency Response","Manage Air Traffic Control"]},{"phase_number":2,"phase_name":"Core Transformation","duration_months":10,"epics":[{"epic_id":"EPIC-20CF3CE1","title":"Manage Tele-Communication","subdomain_group":"Manage Aviation Operation Services","description":"Capability to plan, operate, and govern telecommunication services supporting airport core aviation operations, including voice, data, radio, and network infrastructure. Scoped within Manage Aviation Operation Services to ensure secure, resilient, and compliant communications across airside, terminal, and control environments.","business_value":"Deliver 99.99% telecommunication service availability for aviation operations and reduce operational communication incident response time by 30% through AI-enabled monitoring.","strategic_rationale":"Aligned with Gartner Top Trends 2025 — AI-Powered Digital Transformation: enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, driving modernization of airport telecommunication operations.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Legacy radio and PBX systems may limit integration with AI monitoring, delaying modernization milestones","Non-compliance with ICAO Annex 17 reporting timelines could result in regulatory sanctions and operational disruption"],"estimated_sprints":6,"features":[{"title":"Voice and Radio Communication Services","description":"Provision and manage secure voice and VHF/UHF radio services for ATC, ground handling, and emergency coordination.","technical_notes":"Leverage Generative AI for voice transcription and anomaly detection; Agentic workflows for incident escalation.","user_stories":[{"role":"Air Traffic Operations Manager","want":"reliable encrypted voice and radio channels with AI-assisted monitoring","so_that":"aviation operations remain safe and compliant under all conditions","acceptance_criteria":["All voice channels encrypted end-to-end","AI anomaly detection flags dropped calls within 10 seconds","Redundant failover tested quarterly"],"tasks":[{"title":"Deploy encrypted voice gateway","description":"Install and configure secure SIP/radio gateway aligned to ICAO Annex 17 controls.","estimated_days":6,"assignee_role":"Network Engineer"},{"title":"Integrate AI voice anomaly detection","description":"Implement Generative AI model with vector database for real-time anomaly detection on voice streams.","estimated_days":7,"assignee_role":"AI Engineer"}]}],"estimated_story_points":8},{"title":"Telecom Network Infrastructure Management","description":"Manage core LAN/WAN, fibre backbone, and wireless infrastructure supporting aviation operations.","technical_notes":"Agentic workflows orchestrate change management; AMD MI300X inference accelerates network telemetry analytics.","user_stories":[{"role":"Network Operations Lead","want":"an AI-augmented NOC with predictive fault detection","so_that":"telecom outages affecting aviation services are prevented proactively","acceptance_criteria":["Predictive alerts generated 15 minutes before threshold breach","All network segments documented in CMDB","Access control lists aligned with security restricted area policy"],"tasks":[{"title":"Implement network telemetry platform","description":"Deploy streaming telemetry with vector database store for inference-based analytics.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Configure agentic incident workflows","description":"Automate triage and escalation using agentic workflows integrated with ITSM.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":13},{"title":"Telecom Security and Compliance","description":"Ensure telecom services comply with ICAO Annex 17 and national aviation security programme controls.","technical_notes":"Use Generative AI to automate compliance evidence collection and continuous control monitoring.","user_stories":[{"role":"Security Analyst","want":"continuous compliance monitoring across telecom assets","so_that":"acts of unlawful interference are detected and reported within mandated timelines","acceptance_criteria":["Compliance dashboard updated daily","Unlawful interference incidents reported within 24 hours","Quarterly quality control inspections evidenced"],"tasks":[{"title":"Build compliance evidence pipeline","description":"Automate collection of ICAO Annex 17 control evidence into GRC platform.","estimated_days":6,"assignee_role":"Security Analyst"},{"title":"Configure 24-hour incident reporting","description":"Implement agentic workflow to auto-draft and dispatch unlawful interference reports to authorities.","estimated_days":4,"assignee_role":"Security Engineer"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥99.99% telecom uptime measured monthly across aviation-critical channels","Phase exit: All sub-capabilities deployed to production with signed-off operational readiness review"],"phase":2},{"epic_id":"EPIC-F3543C19","title":"Manage Cargo Handling & Processing","subdomain_group":"Manage Aviation Handling Services","description":"Capability to orchestrate end-to-end cargo handling, screening, and processing operations at the airport, ensuring secure, efficient, and compliant movement of freight. Scope covers aviation handling services within the airport core operations domain, including cargo acceptance, security screening, storage, and release.","business_value":"Reduce cargo processing turnaround time by 25% through AI-driven workflow automation, and improve cargo security compliance rate to 100% against ICAO Annex 17 mandates.","strategic_rationale":"Aligned with Gartner Top Trends 2025 (AI-Powered Digital Transformation): Enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, enabling modernised cargo operations through Generative AI and agentic workflows.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 mandates resulting in regulatory sanctions and loss of operating authorisation","AI model inaccuracy in threat detection or document extraction leading to security breaches or operational delays"],"estimated_sprints":6,"features":[{"title":"Cargo Acceptance & Documentation","description":"Digitised cargo acceptance, AWB validation, and documentation workflows supported by AI-assisted data extraction.","technical_notes":"Leverage Generative AI for document OCR and classification, Vector databases for AWB semantic search, and Agentic workflows for exception handling.","user_stories":[{"role":"Cargo Operations Officer","want":"to digitally capture and validate air waybills at cargo acceptance","so_that":"cargo is processed faster with fewer documentation errors","acceptance_criteria":["AWB data auto-extracted with >95% accuracy","Invalid or incomplete AWBs flagged in real time","Acceptance record integrated with cargo management system"],"tasks":[{"title":"Design AWB ingestion data model","description":"Define canonical data model and validation rules for air waybill capture aligned with IATA Cargo-XML.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build GenAI OCR extraction service","description":"Implement generative AI pipeline for extracting structured fields from scanned AWB documents.","estimated_days":8,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8},{"title":"Cargo Security Screening","description":"Automated cargo screening workflow integrated with approved X-ray and EDS equipment with AI-based threat detection.","technical_notes":"Use AMD MI300X inference for real-time image analysis and Agentic workflows to orchestrate screening exceptions.","user_stories":[{"role":"Aviation Security Officer","want":"AI-assisted threat detection on screened cargo","so_that":"prohibited items are identified with higher accuracy and speed","acceptance_criteria":["All cargo screened via approved equipment with results logged","Threat alerts raised within 5 seconds of scan completion","Screening audit trail retained for minimum 90 days"],"tasks":[{"title":"Integrate screening equipment APIs","description":"Connect X-ray and EDS devices to central screening platform using standard ICAO-compliant interfaces.","estimated_days":7,"assignee_role":"Integration Engineer"},{"title":"Deploy AI threat detection model","description":"Host threat-detection inference on AMD MI300X and integrate with screening workflow.","estimated_days":9,"assignee_role":"ML Engineer"},{"title":"Configure alert and audit logging","description":"Implement SIEM integration to record screening outcomes and unlawful interference events.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Cargo Storage & Warehouse Management","description":"Smart warehouse slotting, tracking, and release management for accepted cargo with access control enforcement.","technical_notes":"Vector databases for similarity-based slot optimisation and Agentic workflows for automated release orchestration.","user_stories":[{"role":"Warehouse Supervisor","want":"real-time visibility and access-controlled management of cargo in storage","so_that":"cargo integrity and security are maintained until release","acceptance_criteria":["Every cargo unit tracked with location and status in real time","Only authorised personnel can access security restricted zones","Cargo release events reconciled against AWB and customs clearance"],"tasks":[{"title":"Implement RFID-based cargo tracking","description":"Deploy RFID readers and tags across the cargo warehouse zones for location tracking.","estimated_days":8,"assignee_role":"IoT Engineer"},{"title":"Enforce access control integration","description":"Integrate warehouse access control with IAM to restrict security-restricted area entry.","estimated_days":5,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Compliance & Quality Control Reporting","description":"Automated compliance reporting aligned to ICAO Annex 17 including quality control inspections and unlawful interference reporting.","technical_notes":"Generative AI for report drafting and Agentic workflows for 24-hour incident escalation.","user_stories":[{"role":"Compliance Manager","want":"automated generation and submission of regulatory reports","so_that":"the authority remains continuously compliant with ICAO Annex 17","acceptance_criteria":["Quality control inspection schedule executed and evidenced monthly","Unlawful interference incidents auto-escalated within 24 hours","NASP compliance dashboard available to executives"],"tasks":[{"title":"Build compliance reporting dashboard","description":"Develop executive dashboard summarising NASP compliance KPIs and inspection outcomes.","estimated_days":6,"assignee_role":"BI Developer"},{"title":"Automate 24-hour incident reporting","description":"Implement agentic workflow to draft and submit unlawful interference reports within SLA.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 25% reduction in average cargo dwell time measured over 4 consecutive weeks post go-live","All cargo handling workflows pass UAT sign-off and transition to production within 12-week delivery window"],"phase":2},{"epic_id":"EPIC-DE240A7C","title":"Manage Baggage Handling & Processing","subdomain_group":"Manage Aviation Handling Services","description":"This capability governs the end-to-end processing, tracking, screening, and reconciliation of passenger baggage across the airport to ensure secure, timely, and accurate delivery. It operates within the Manage Aviation Handling Services subdomain under Airport Core Operations, integrating with airline, security, and ground handling systems.","business_value":"Reduce mishandled baggage rates by 25% and improve on-time baggage delivery to aircraft and carousels by 30%, directly enhancing passenger experience and airline SLA compliance.","strategic_rationale":"Aligned with Gartner Top Trends 2025 (AI-Powered Digital Transformation): enterprises leveraging AI report 20-30% productivity gains and 15% cost reduction, enabling intelligent baggage routing, predictive exception handling, and automated security screening at scale.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Integration complexity between legacy BHS/DCS and new AI inference platforms may delay go-live","Regulatory non-compliance with ICAO Annex 17 access control or 24-hour reporting obligations could result in certification findings"],"estimated_sprints":6,"features":[{"title":"Baggage Check-in & Acceptance","description":"Enables acceptance, tagging, and initial routing of passenger baggage at check-in counters and self-service kiosks.","technical_notes":"Leverage Generative AI chat assistants for passenger self-service and Agentic workflows to automate tag issuance and exception routing.","user_stories":[{"role":"Check-in Agent","want":"to accept and tag baggage with IATA-compliant barcodes and RFID","so_that":"bags can be tracked end-to-end across the handling system","acceptance_criteria":["Bag tag generated with unique 10-digit license plate","RFID encoding verified against BSM message","Oversize/overweight bags flagged for manual handling"],"tasks":[{"title":"Design baggage tagging integration","description":"Define integration between DCS, BHS, and tag printers aligned with IATA Resolution 753.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Implement RFID encoding service","description":"Build microservice for RFID tag encoding and validation at check-in points.","estimated_days":7,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8},{"title":"Hold Baggage Screening","description":"Automated multi-level security screening of hold baggage using approved EDS equipment integrated with the BHS.","technical_notes":"Use Vector databases to store threat image signatures and AMD MI300X inference for real-time AI-assisted threat detection.","user_stories":[{"role":"Security Screening Officer","want":"to screen all hold baggage with AI-augmented threat detection","so_that":"prohibited items are identified and aviation security is maintained","acceptance_criteria":["100% of hold bags pass through Level 1 EDS","Alarm bags routed to Level 2/3 within SLA","Audit log retained for 90 days"],"tasks":[{"title":"Integrate EDS with BHS control system","description":"Configure SCADA-level integration between explosive detection systems and baggage sortation.","estimated_days":8,"assignee_role":"Security Analyst"},{"title":"Deploy AI threat detection inference","description":"Deploy ML models on AMD MI300X for real-time threat image classification assistance.","estimated_days":10,"assignee_role":"ML Engineer"},{"title":"Configure unlawful interference reporting","description":"Automate 24-hour incident reporting workflow to national authority per ICAO Annex 17.","estimated_days":4,"assignee_role":"Compliance Analyst"}]}],"estimated_story_points":13},{"title":"Baggage Sortation & Tracking","description":"Real-time routing of screened baggage to correct make-up positions using conveyor sortation and tracking.","technical_notes":"Agentic workflows orchestrate exception handling; Vector databases enable similarity search for lost bag reconciliation.","user_stories":[{"role":"Baggage Operations Controller","want":"real-time visibility of every bag\'s location and status","so_that":"I can proactively resolve exceptions before flight departure","acceptance_criteria":["Bag location refreshed every 5 seconds","Exception alerts sent within 30 seconds","IATA 753 tracking milestones captured"],"tasks":[{"title":"Build baggage tracking dashboard","description":"Develop operations dashboard visualising live bag flow and KPIs.","estimated_days":6,"assignee_role":"Full-stack Developer"},{"title":"Implement agentic exception workflows","description":"Create AI agents to auto-route jammed, mis-sorted, and late bags per defined playbooks.","estimated_days":9,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8},{"title":"Baggage Reconciliation & Access Control","description":"Ensures bags travel only with ticketed passengers and restricts access to baggage handling security zones.","technical_notes":"Biometric and RFID-based access control integrated with NASP-compliant identity management.","user_stories":[{"role":"Ramp Supervisor","want":"automated passenger-bag reconciliation before aircraft loading","so_that":"no unaccompanied bags are loaded onto departing flights","acceptance_criteria":["BRS confirms passenger boarded before loading","Unaccompanied bags offloaded and logged","Access to SRA restricted to authorised staff only"],"tasks":[{"title":"Configure BRS passenger reconciliation","description":"Integrate boarding system with baggage reconciliation to prevent unaccompanied bag loading.","estimated_days":6,"assignee_role":"Integration Engineer"},{"title":"Deploy SRA access control system","description":"Install biometric readers and policies governing access to security restricted baggage areas.","estimated_days":7,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Quality Control & Compliance Monitoring","description":"Continuous inspection, audit, and reporting of baggage security measures aligned with NASP.","technical_notes":"Generative AI summarises audit findings; dashboards track compliance KPIs in real time.","user_stories":[{"role":"Compliance Auditor","want":"scheduled and ad-hoc quality control inspections with digital evidence capture","so_that":"regulatory obligations under ICAO Annex 17 are demonstrably met","acceptance_criteria":["Monthly QC inspection checklist completed","Non-conformance actions tracked to closure","Evidence retained for 2 years"],"tasks":[{"title":"Build QC inspection module","description":"Develop digital workflow for scheduled inspections with photo and sensor evidence capture.","estimated_days":6,"assignee_role":"Business Analyst"},{"title":"Implement compliance reporting engine","description":"Generate automated NASP compliance reports and 24-hour unlawful interference notifications.","estimated_days":5,"assignee_role":"Data Engineer"}]}],"estimated_story_points":5}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve <5 mishandled bags per 1,000 passengers measured over 4 consecutive weeks post go-live","Phase exit: End-to-end baggage flow validated in UAT with 99.5% tracking accuracy and security sign-off obtained"],"phase":2},{"epic_id":"EPIC-F810D5C4","title":"Manage Meteorological Services","subdomain_group":"Manage Aviation Operation Services","description":"","business_value":"","strategic_rationale":"Enterprises using AI report 20-30% productivity gains and 15% cost reduction on average","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":[],"estimated_sprints":6,"features":[],"acceptance_criteria":["[Compliance] Implement national aviation security programme (NASP)","[Compliance] Screen all passengers and carry-on baggage using approved equipment","[Compliance] Maintain access control to security restricted areas","[Compliance] Conduct quality control inspections of security measures","[Compliance] Report all acts of unlawful interference within 24 hours"],"phase":2},{"epic_id":"EPIC-2076269F","title":"Manage Asset Disposal","subdomain_group":"Manage Infrastructure Asset Lifecyle","description":"Capability to manage the end-of-life disposal of airport infrastructure assets including decommissioning, secure data wiping, asset valuation, and compliant disposition. Operates within the Manage Infrastructure Asset Lifecycle subdomain to ensure aviation security continuity during asset retirement.","business_value":"Recover residual asset value through structured resale and recycling programmes, and reduce compliance exposure by ensuring all disposed assets meet ICAO security and environmental standards.","strategic_rationale":"Per Gartner Top Trends 2025, enterprises using AI report 20-30% productivity gains and 15% cost reduction on average; applying AI-powered digital transformation to asset disposal workflows accelerates decommissioning decisions and optimises recovery value.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Residual sensitive data on improperly sanitised assets leading to ICAO Annex 17 breach","AI valuation model bias causing under-recovery of asset resale value"],"estimated_sprints":6,"features":[{"title":"Asset Decommissioning & Retirement Planning","description":"Plan and orchestrate retirement of infrastructure assets with security-aware workflows.","technical_notes":"Agentic workflows orchestrate decommissioning checklists; Generative AI drafts retirement plans from asset metadata stored in vector databases.","user_stories":[{"role":"Asset Manager","want":"an AI-assisted decommissioning planner that generates retirement schedules per asset class","so_that":"I can retire assets safely without disrupting airside operations","acceptance_criteria":["Planner ingests CMDB asset records and proposes retirement dates","Security-restricted assets trigger NASP review workflow","All plans require approval from Operations and Security leads"],"tasks":[{"title":"Design decommissioning workflow blueprint","description":"Define agentic workflow stages aligned to ICAO Annex 17 controls and CMDB lifecycle states.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build GenAI retirement plan generator","description":"Implement LLM service that drafts retirement plans using vector-indexed asset history.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Integrate access control validation","description":"Hook planner into IAM to verify access control to security restricted areas before approval.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Secure Data Sanitisation & Media Disposal","description":"Ensure all data-bearing assets are sanitised or destroyed per aviation security standards prior to disposal.","technical_notes":"Agentic workflows enforce NIST 800-88 wipe procedures; AMD MI300X inference accelerates anomaly detection on sanitisation logs.","user_stories":[{"role":"Security Analyst","want":"automated verification of data sanitisation events with chain-of-custody evidence","so_that":"no sensitive aviation data leaks through disposed assets","acceptance_criteria":["All data-bearing assets logged with wipe certificate","Screen all passengers and carry-on baggage using approved equipment policy referenced for screening-tier assets","Unlawful interference attempts during disposal reported within 24 hours"],"tasks":[{"title":"Implement sanitisation evidence ledger","description":"Build tamper-evident log capturing wipe certificates and operator signatures.","estimated_days":6,"assignee_role":"Data Engineer"},{"title":"Deploy MI300X anomaly inference service","description":"Train and host model detecting irregular sanitisation patterns on AMD MI300X.","estimated_days":7,"assignee_role":"ML Engineer"}]}],"estimated_story_points":8},{"title":"Asset Valuation, Resale & Recycling","description":"Determine residual value and route assets to resale, recycling, or destruction channels.","technical_notes":"Generative AI estimates resale value from market data; vector databases enable similarity search across historical disposals.","user_stories":[{"role":"Finance Analyst","want":"AI-driven residual valuation and disposition recommendations","so_that":"the airport maximises recovery value and minimises disposal cost","acceptance_criteria":["Valuation model returns confidence-scored estimate per asset","Disposition route auto-recommended (resale, recycle, destroy)","Quality control inspection sign-off recorded before disposal"],"tasks":[{"title":"Train residual valuation model","description":"Build regression model using historical disposal proceeds and market benchmarks.","estimated_days":6,"assignee_role":"Data Scientist"},{"title":"Build vendor disposition portal","description":"Expose approved-vendor portal for bidding, pickup scheduling and certificate upload.","estimated_days":8,"assignee_role":"Full-Stack Developer"}]}],"estimated_story_points":8},{"title":"Disposal Compliance & Audit Reporting","description":"Provide end-to-end audit trail and regulatory reporting for all disposed assets.","technical_notes":"Vector databases index audit evidence; Generative AI summarises compliance posture for regulators.","user_stories":[{"role":"Compliance Officer","want":"an automated disposal compliance dashboard with regulator-ready reports","so_that":"ICAO and national audits can be satisfied with minimal manual effort","acceptance_criteria":["Dashboard surfaces NASP-linked controls per disposal case","Reports exportable in ICAO Annex 17 format","Quality control inspection findings tracked to closure"],"tasks":[{"title":"Configure compliance KPI dashboard","description":"Build BI dashboard tracking disposal cycle time, exception rate and audit readiness.","estimated_days":5,"assignee_role":"BI Developer"},{"title":"Implement 24-hour incident reporting flow","description":"Automate notification pipeline to report unlawful interference within 24 hours.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":5}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 95% of disposal cases closed within 30 days of decommissioning approval","Phase exit: all in-scope assets reconciled in CMDB with disposal certificates archived and audited","[Compliance] Screen all passengers and carry-on baggage using approved equipment"],"phase":2},{"epic_id":"EPIC-CA2FCA79","title":"Manage Asset Maintenance","subdomain_group":"Manage Infrastructure Asset Lifecyle","description":"Capability to manage the end-to-end maintenance of airport infrastructure assets including preventive, predictive, and corrective maintenance activities. Scope covers the Manage Infrastructure Asset Lifecycle subdomain within Airport Core Operations, ensuring asset reliability, safety, and compliance with aviation regulations.","business_value":"Reduce unplanned asset downtime by 25% and extend asset useful life by 15% through AI-driven predictive maintenance, improving operational resilience and passenger safety across airport infrastructure.","strategic_rationale":"Per Gartner Top Trends 2025 (AI-Powered Digital Transformation), enterprises adopting AI report 20-30% productivity gains and 15% cost reduction on average, directly applicable to maintenance workflows via agentic automation and generative AI-assisted diagnostics.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["AI model drift may reduce predictive accuracy over time requiring ongoing retraining and MLOps investment","Integration complexity with legacy CMMS and SCADA systems may delay delivery beyond 12-week window"],"estimated_sprints":6,"features":[{"title":"Preventive Maintenance Scheduling","description":"Automate scheduling of recurring preventive maintenance tasks for airport infrastructure assets.","technical_notes":"Leverage Agentic workflows and Generative AI to auto-generate work orders; integrate with CMMS and Vector databases for historical task retrieval.","user_stories":[{"role":"Maintenance Planner","want":"to auto-generate preventive maintenance work orders based on asset criticality and usage","so_that":"critical airport assets remain operational and compliant with safety regulations","acceptance_criteria":["System generates work orders 7 days ahead of due date","Work orders routed to correct technician group","Compliance tag applied per ICAO Annex 17 where applicable"],"tasks":[{"title":"Configure PM scheduling rules engine","description":"Define rule sets for PM frequency based on asset class, criticality, and manufacturer guidance aligned to ISO 55000.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Integrate CMMS with agentic workflow","description":"Build API integration between CMMS and agentic AI workflow orchestrator for auto work-order creation.","estimated_days":7,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8},{"title":"Predictive Maintenance Analytics","description":"Apply AI/ML models to sensor and historical data to predict asset failures before they occur.","technical_notes":"Use AMD MI300X inference for ML model serving and Vector databases for similarity search on failure patterns.","user_stories":[{"role":"Reliability Engineer","want":"to receive predictive failure alerts for runway lighting and HVAC assets","so_that":"maintenance can be performed before asset failure impacts operations","acceptance_criteria":["Model precision >=85% on validation set","Alerts delivered to mobile app within 5 minutes of detection","Historical failure patterns retrievable via vector search"],"tasks":[{"title":"Train failure prediction models","description":"Develop and validate ML models on historical sensor data using AMD MI300X inference platform.","estimated_days":10,"assignee_role":"Data Scientist"},{"title":"Deploy vector database for pattern retrieval","description":"Stand up vector database indexing historical failure signatures for similarity-based diagnostic assistance.","estimated_days":6,"assignee_role":"Data Engineer"}]}],"estimated_story_points":13},{"title":"Corrective Maintenance & Work Order Management","description":"Manage reactive corrective maintenance with AI-assisted triage and technician dispatch.","technical_notes":"Generative AI summarises fault descriptions; agentic workflows route work orders to available technicians with skill matching.","user_stories":[{"role":"Maintenance Supervisor","want":"AI-assisted triage of incoming fault reports","so_that":"high-priority corrective work is dispatched quickly to restore asset availability","acceptance_criteria":["Fault classification accuracy >=90%","Work order dispatched within 10 minutes of fault report","Audit trail preserved for compliance inspections"],"tasks":[{"title":"Implement GenAI fault triage agent","description":"Deploy generative AI agent to classify fault reports and recommend priority per ISO 55000 risk criteria.","estimated_days":6,"assignee_role":"AI/ML Engineer"},{"title":"Build technician dispatch workflow","description":"Configure agentic workflow to match work orders to available technicians by skill, location, and certification.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8},{"title":"Asset Maintenance Compliance & Reporting","description":"Provide compliance dashboards and regulatory reporting for maintenance activities on security-restricted assets.","technical_notes":"Generative AI auto-drafts compliance reports; integration with security access control systems per ICAO Annex 17.","user_stories":[{"role":"Compliance Officer","want":"automated compliance reports for maintenance activities in security restricted areas","so_that":"regulatory obligations under ICAO Annex 17 are continuously met","acceptance_criteria":["Reports generated monthly with no manual rework","All unlawful interference events reported within 24 hours","Dashboard shows real-time compliance posture"],"tasks":[{"title":"Build compliance reporting dashboard","description":"Implement dashboard visualising KPIs and ICAO Annex 17 compliance metrics for maintenance activities.","estimated_days":6,"assignee_role":"BI Developer"},{"title":"Automate 24-hour incident reporting","description":"Configure agentic workflow to auto-generate and submit unlawful interference reports within 24 hours of event.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":5}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve >=95% preventive maintenance schedule compliance measured monthly","Phase exit: All maintenance sub-capabilities deployed to production with signed-off UAT and compliance audit by week 12"],"phase":2},{"epic_id":"EPIC-18B18C90","title":"Manage Asset Operation","subdomain_group":"Manage Infrastructure Asset Lifecyle","description":"This capability enables the Airport Authority to operate, maintain, and optimise airport infrastructure assets throughout their lifecycle, ensuring safe, secure, and compliant operations. It covers the Manage Infrastructure Asset Lifecycle subdomain within the Manage Airport Core Operation domain, integrating asset performance, security compliance, and operational readiness.","business_value":"Improved asset availability and operational uptime across airport infrastructure, and enhanced security posture with reduced compliance exposure against ICAO Annex 17 obligations.","strategic_rationale":"Aligned with Gartner Top Trends 2025 \'AI-Powered Digital Transformation\': enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, enabling predictive asset operations and intelligent security screening.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Regulatory non-conformance with ICAO Annex 17 during transition to AI-enabled operations","AI model drift or false negatives in predictive maintenance and security screening impacting safety outcomes"],"estimated_sprints":6,"features":[{"title":"Asset Lifecycle Monitoring & Predictive Maintenance","description":"AI-driven monitoring of airport infrastructure assets to predict failures and optimise maintenance cycles.","technical_notes":"Generative AI for maintenance insights, Agentic workflows for work order orchestration, AMD MI300X inference for real-time telemetry scoring, Vector databases for asset knowledge retrieval.","user_stories":[{"role":"Asset Operations Manager","want":"a predictive maintenance dashboard for critical airport assets","so_that":"unplanned downtime is reduced and asset lifecycle cost is optimised","acceptance_criteria":["Dashboard ingests telemetry from ≥95% of critical assets","Predictive model achieves ≥85% precision on failure alerts","Work orders auto-generated via agentic workflow on high-risk alerts"],"tasks":[{"title":"Design asset telemetry ingestion architecture","description":"Define data contracts and streaming pipeline aligned to enterprise asset management framework.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build predictive maintenance ML pipeline","description":"Train and deploy failure-prediction models on AMD MI300X inference infrastructure.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Implement agentic work order automation","description":"Configure agentic workflow to trigger CMMS work orders from predictive alerts.","estimated_days":6,"assignee_role":"Automation Engineer"}]}],"estimated_story_points":13},{"title":"Aviation Security Screening & Access Control","description":"Operate ICAO Annex 17 compliant screening and access control across security restricted areas.","technical_notes":"Generative AI for anomaly narratives, Vector databases for threat pattern retrieval, Agentic workflows for incident escalation.","user_stories":[{"role":"Aviation Security Officer","want":"integrated screening and access control aligned to NASP","so_that":"unlawful interference risks are detected and reported within regulatory SLAs","acceptance_criteria":["100% of passengers and carry-on baggage screened with approved equipment","Access control logs retained and auditable for security restricted areas","Unlawful interference incidents reported within 24 hours"],"tasks":[{"title":"Deploy NASP-aligned screening workflow","description":"Configure screening lanes and approved equipment per ICAO Annex 17 controls.","estimated_days":7,"assignee_role":"Security Analyst"},{"title":"Integrate access control with identity platform","description":"Federate SRA access with enterprise IAM and audit logging.","estimated_days":6,"assignee_role":"Security Engineer"},{"title":"Implement 24-hour incident reporting automation","description":"Agentic workflow to notify regulator and generate compliance evidence pack.","estimated_days":4,"assignee_role":"Compliance Engineer"}]}],"estimated_story_points":13},{"title":"Quality Control & Compliance Assurance","description":"Continuous quality control inspections and compliance evidence management for security and asset operations.","technical_notes":"Generative AI for inspection report drafting, Vector databases for regulation retrieval, Agentic workflows for corrective actions.","user_stories":[{"role":"Compliance Auditor","want":"a quality control inspection system with AI-assisted evidence management","so_that":"ICAO Annex 17 conformance is demonstrable and audit-ready","acceptance_criteria":["Inspection schedule covers 100% of security measures quarterly","Findings tracked to closure with SLA adherence ≥95%","Evidence pack auto-generated per inspection cycle"],"tasks":[{"title":"Configure inspection scheduling engine","description":"Build recurring inspection cadence aligned to ICAO Annex 17 quality control requirements.","estimated_days":4,"assignee_role":"Business Analyst"},{"title":"Build AI-assisted evidence repository","description":"Vector-database-backed repository for regulation mapping and evidence retrieval.","estimated_days":6,"assignee_role":"Data Engineer"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥99.5% critical asset availability and ≥20% productivity uplift from AI-enabled operations within 12 weeks","Phase exit: all compliance ACs evidenced, UAT signed off, and operational runbooks handed over to Ops"],"phase":2}],"objectives":["Deliver 99.99% telecommunication service availability for aviation operations and reduce operational communication incident response time by 30% through AI-enabled monitoring.","Reduce cargo processing turnaround time by 25% through AI-driven workflow automation, and improve cargo security compliance rate to 100% against ICAO Annex 17 mandates.","Reduce mishandled baggage rates by 25% and improve on-time baggage delivery to aircraft and carousels by 30%, directly enhancing passenger experience and airline SLA compliance."],"key_milestones":["Manage Tele-Communication","Manage Cargo Handling & Processing"]},{"phase_number":3,"phase_name":"Advanced Capabilities","duration_months":14,"epics":[{"epic_id":"EPIC-9D682DB3","title":"Manage Asset Planning","subdomain_group":"Manage Infrastructure Asset Lifecyle","description":"Capability to plan, prioritise, and govern airport infrastructure assets across their lifecycle to ensure operational resilience, safety, and regulatory compliance. Scoped within Manage Infrastructure Asset Lifecycle to support strategic asset investment, condition-based planning, and security-aligned asset governance.","business_value":"Improved asset availability and reduced unplanned downtime through predictive planning; enhanced capital investment decisions aligned to operational risk and passenger experience outcomes.","strategic_rationale":"Aligned to Gartner Top Trends 2025 — AI-Powered Digital Transformation: Enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, enabling data-driven asset planning and agentic workflows for airport operations.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["AI model bias or inaccuracy leading to mis-prioritised investments and potential safety or security exposure","Non-compliance with ICAO Annex 17 if access control, QC inspections, or 24-hour incident reporting are not fully operationalised within the 12-week window"],"estimated_sprints":6,"features":[{"title":"Asset Portfolio & Investment Planning","description":"Establish an AI-enabled asset portfolio planning capability that prioritises capital investments against risk, compliance, and operational value.","technical_notes":"Leverage Generative AI for scenario modelling, Vector databases for asset knowledge retrieval, and Agentic workflows to automate portfolio optimisation.","user_stories":[{"role":"Asset Planning Manager","want":"an AI-assisted portfolio dashboard that ranks infrastructure investments by risk and value","so_that":"capital spend is optimised and aligned to airport safety and security priorities","acceptance_criteria":["Dashboard ingests asset register, condition, and incident data","AI model produces ranked investment scenarios with confidence scores","NASP-aligned security assets are flagged as priority"],"tasks":[{"title":"Design asset portfolio data model","description":"Define canonical asset, condition, and investment data model aligned to TOGAF information architecture standards.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build GenAI scenario planner","description":"Implement Generative AI service with vector database retrieval to generate ranked investment scenarios.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Validate ICAO security asset flags","description":"Configure rules to flag NASP-critical assets and validate with aviation security stakeholders.","estimated_days":3,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Asset Condition & Risk Assessment","description":"Enable predictive condition monitoring and risk assessment of airport infrastructure assets to inform planning decisions.","technical_notes":"Use Agentic workflows and AMD MI300X inference for high-throughput predictive analytics on IoT and inspection data.","user_stories":[{"role":"Infrastructure Engineer","want":"predictive condition and risk scoring for critical assets","so_that":"I can proactively plan interventions before failures impact operations or security","acceptance_criteria":["Condition scores computed for 100% of in-scope assets","Risk scores integrate aviation security impact per ICAO Annex 17","Quality control inspection outcomes feed the model"],"tasks":[{"title":"Ingest IoT and inspection data","description":"Build data pipelines from SCADA, IoT sensors, and inspection logs into the asset analytics platform.","estimated_days":6,"assignee_role":"Data Engineer"},{"title":"Deploy predictive model on MI300X","description":"Train and deploy condition-prediction model using AMD MI300X inference infrastructure for low-latency scoring.","estimated_days":7,"assignee_role":"ML Engineer"},{"title":"Integrate QC inspection workflow","description":"Embed ICAO-aligned quality control inspection results into the risk scoring engine.","estimated_days":4,"assignee_role":"Business Analyst"}]}],"estimated_story_points":8},{"title":"Asset Planning Governance & Compliance","description":"Establish governance, access control, and reporting aligned to ICAO Annex 17 for asset planning decisions affecting security restricted areas.","technical_notes":"Implement RBAC, audit logging, and agentic compliance reporting using Generative AI summarisation.","user_stories":[{"role":"Aviation Security Officer","want":"automated compliance reporting and controlled access for asset planning changes","so_that":"unlawful interference and control gaps are detected and reported within mandated timelines","acceptance_criteria":["Access control enforced on security restricted area asset records","Unlawful interference reporting workflow triggers within 24 hours","Compliance reports auto-generated for regulator review"],"tasks":[{"title":"Configure RBAC for restricted assets","description":"Implement role-based access control and segregation of duties for security restricted area asset data.","estimated_days":4,"assignee_role":"Security Analyst"},{"title":"Build 24-hour incident reporting workflow","description":"Develop agentic workflow to detect, escalate, and report acts of unlawful interference within 24 hours per ICAO Annex 17.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Automate NASP compliance reporting","description":"Use Generative AI to summarise asset planning evidence into NASP compliance reports for quality control inspections.","estimated_days":5,"assignee_role":"Compliance Analyst"}]}],"estimated_story_points":5}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥95% asset data completeness and ≥90% planning forecast accuracy within 12 weeks","Phase exit: Asset Planning target operating model approved, AI planning MVP deployed to production, and ICAO Annex 17 compliance evidence signed off by CISO"],"phase":3},{"epic_id":"EPIC-B32606BF","title":"Manage Duty Free Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"Capability to operate, govern, and optimise duty free retail concessions across airport terminals, ensuring compliance with aviation security, customs regulations, and commercial performance targets. Scope covers non-aviation commercial services within airport core operations, including retail tenant management, passenger experience, and revenue assurance.","business_value":"Increase non-aeronautical revenue per passenger by 15% through AI-driven personalisation, and improve duty free concession operational efficiency by 25% via automated compliance and inventory workflows.","strategic_rationale":"Aligned with Gartner Top Trends 2025 (AI-Powered Digital Transformation): enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, directly applicable to duty free retail operations, passenger engagement, and security compliance.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 controls in retail-adjacent security-restricted areas may result in regulatory sanctions and reputational damage.","AI personalisation models may introduce bias or privacy breaches, undermining passenger trust and GDPR compliance."],"estimated_sprints":6,"features":[{"title":"Duty Free Concession Management","description":"Manage tenant onboarding, lease performance, and concession contract lifecycle for duty free operators.","technical_notes":"Agentic workflows for contract monitoring; Generative AI for lease clause analysis; Vector databases for contract similarity search.","user_stories":[{"role":"Commercial Concessions Manager","want":"a unified dashboard to monitor duty free tenant performance and contract compliance","so_that":"underperforming concessions are identified early and revenue is optimised","acceptance_criteria":["Dashboard shows real-time sales and MAG (Minimum Annual Guarantee) status per tenant","AI alerts flag contract breaches within 24 hours","Integrates with finance ERP for reconciliation"],"tasks":[{"title":"Design concession data model","description":"Define entities for tenants, leases, sales, and MAG obligations aligned to TOGAF data architecture.","estimated_days":4,"assignee_role":"Solutions Architect"},{"title":"Build tenant performance dashboard","description":"Develop Power BI/Tableau dashboard surfacing sales, MAG, and compliance KPIs.","estimated_days":6,"assignee_role":"Data Engineer"},{"title":"Configure AI contract-breach alerts","description":"Implement generative AI agent to parse contract terms and trigger breach notifications.","estimated_days":5,"assignee_role":"AI/ML Engineer"}]}],"estimated_story_points":8},{"title":"Passenger Personalisation & Retail Engagement","description":"Deliver AI-driven personalised offers and product recommendations to duty free shoppers.","technical_notes":"Generative AI for personalised offers; Vector databases for product embeddings; AMD MI300X inference for low-latency recommendations.","user_stories":[{"role":"Digital Retail Product Owner","want":"personalised duty free recommendations delivered via app and in-store displays","so_that":"spend per passenger increases and passenger experience is enhanced","acceptance_criteria":["Recommendations generated within 200ms latency","Opt-in consent captured per GDPR","A/B test shows ≥10% uplift in conversion"],"tasks":[{"title":"Deploy vector database for product catalogue","description":"Ingest product metadata and embeddings into a managed vector database.","estimated_days":5,"assignee_role":"Data Engineer"},{"title":"Develop recommendation microservice","description":"Build inference microservice on AMD MI300X runtime with REST API.","estimated_days":7,"assignee_role":"AI/ML Engineer"},{"title":"Integrate with airport mobile app","description":"Expose recommendation API to the airport passenger app and in-store kiosks.","estimated_days":4,"assignee_role":"Full-Stack Developer"}]}],"estimated_story_points":13},{"title":"Security & Compliance Integration for Retail Zones","description":"Ensure duty free zones comply with ICAO Annex 17 access control, screening, and quality inspection obligations.","technical_notes":"Agentic workflows for automated compliance evidence collection; AI-driven anomaly detection for access control logs.","user_stories":[{"role":"Aviation Security Officer","want":"automated compliance monitoring and incident reporting for duty free security-restricted zones","so_that":"ICAO Annex 17 obligations are continuously met and unlawful interference is reported within 24 hours","acceptance_criteria":["All access events logged and auditable","Quality control inspection schedule automated","Incident reports auto-drafted and dispatched within 24 hours"],"tasks":[{"title":"Integrate access control with SIEM","description":"Stream duty free zone badge events to central SIEM for correlation and audit.","estimated_days":5,"assignee_role":"Security Analyst"},{"title":"Build NASP compliance evidence workflow","description":"Agentic workflow to collect, tag, and archive compliance evidence aligned to NASP.","estimated_days":6,"assignee_role":"Security Analyst"},{"title":"Implement 24-hour incident reporting automation","description":"Generative AI drafts incident reports for acts of unlawful interference within SLA.","estimated_days":4,"assignee_role":"AI/ML Engineer"}]}],"estimated_story_points":8},{"title":"Duty Free Inventory & Revenue Assurance","description":"Provide near real-time inventory visibility, sales reconciliation, and revenue assurance across concessionaires.","technical_notes":"Agentic workflows for reconciliation; Generative AI for anomaly narratives; Vector databases for transaction similarity.","user_stories":[{"role":"Revenue Assurance Analyst","want":"automated reconciliation between POS, inventory, and tenant declarations","so_that":"revenue leakage is eliminated and MAG shortfalls are detected promptly","acceptance_criteria":["Daily reconciliation completed by 08:00 local time","Variances >1% auto-flagged with AI-generated explanation","Audit trail retained for 7 years"],"tasks":[{"title":"Build POS-to-ERP reconciliation pipeline","description":"ETL pipeline reconciling POS transactions against ERP and tenant declarations.","estimated_days":6,"assignee_role":"Data Engineer"},{"title":"Develop AI variance explainer","description":"Generative AI generates natural-language explanations for flagged variances.","estimated_days":4,"assignee_role":"AI/ML Engineer"},{"title":"Configure audit retention and access","description":"Set up immutable 7-year audit archive with role-based access controls.","estimated_days":3,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve ≥15% uplift in duty free revenue per passenger within 12 weeks of go-live","Phase exit: all sub-capabilities deployed to production with signed-off UAT, security review, and ICAO Annex 17 compliance evidence"],"phase":3},{"epic_id":"EPIC-7B5813D6","title":"Manage Exchange Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"Capability to manage currency exchange and related financial services offered to passengers and visitors within airport non-aviation commercial operations. Scope covers the governance, operational oversight, and digital enablement of exchange service concessions under the Manage Non-Aviation Commercial Services subdomain.","business_value":"Increase non-aeronautical revenue from exchange service concessions by 15% and improve passenger satisfaction scores for financial services availability by 20%.","strategic_rationale":"Aligned with Gartner Top Trends 2025 (AI-Powered Digital Transformation): Enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, enabling smarter concession management and secure exchange operations.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 could result in regulatory sanctions and concession revocation","AI anomaly detection model drift may cause false positives impacting concessionaire operations and revenue"],"estimated_sprints":6,"features":[{"title":"Exchange Concession Onboarding & Governance","description":"Digitally onboard and govern currency exchange concessionaires across airport terminals.","technical_notes":"Leverage Generative AI for contract drafting and Agentic workflows for approval routing; Vector databases for tenant document search.","user_stories":[{"role":"Commercial Services Manager","want":"to onboard new exchange concessionaires through a digital workflow","so_that":"concession activation time is reduced and compliance is ensured","acceptance_criteria":["Digital onboarding portal available with KYC validation","Contracts auto-generated using Generative AI templates","NASP compliance checklist embedded in workflow"],"tasks":[{"title":"Design onboarding workflow blueprint","description":"Map concessionaire onboarding stages aligned to airport commercial governance frameworks.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Build GenAI contract drafting module","description":"Develop generative AI service to draft concession contracts from templates.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Embed NASP compliance checks","description":"Integrate ICAO Annex 17 NASP checklist validation into onboarding steps.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Exchange Rate & Transaction Monitoring","description":"Real-time monitoring of exchange rates and transactions across concession outlets.","technical_notes":"Agentic workflows for anomaly detection; AMD MI300X inference for high-throughput transaction analysis; Vector databases for pattern matching.","user_stories":[{"role":"Finance Operations Analyst","want":"to monitor exchange transactions in real time with AI-driven anomaly alerts","so_that":"fraudulent or non-compliant transactions are detected early","acceptance_criteria":["Real-time dashboard shows transaction volume and rate variances","AI anomaly detection triggers alerts within 60 seconds","Unlawful interference incidents are reported within 24 hours"],"tasks":[{"title":"Deploy transaction streaming pipeline","description":"Build streaming data pipeline ingesting exchange transactions from concession POS.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Implement AI anomaly detection model","description":"Train and deploy anomaly detection model on AMD MI300X inference platform.","estimated_days":9,"assignee_role":"ML Engineer"},{"title":"Build monitoring dashboard","description":"Develop operations dashboard visualising transaction KPIs and alerts.","estimated_days":5,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":13},{"title":"Security & Access Control for Exchange Outlets","description":"Enforce access control and quality inspections for exchange outlets within security restricted areas.","technical_notes":"Agentic workflows automate inspection scheduling; Vector databases store inspection evidence for fast retrieval.","user_stories":[{"role":"Aviation Security Officer","want":"to manage access control and conduct quality inspections for exchange outlets","so_that":"ICAO Annex 17 compliance is sustained across concessions","acceptance_criteria":["Access control logs retained and auditable for 12 months","Quality control inspections scheduled and logged quarterly","Screening records linked to outlet compliance profile"],"tasks":[{"title":"Integrate access control system","description":"Connect exchange outlet badge readers to central access management platform.","estimated_days":6,"assignee_role":"Security Analyst"},{"title":"Automate inspection scheduling agent","description":"Build agentic workflow to schedule and track security quality inspections.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Configure unlawful interference reporting","description":"Implement 24-hour incident reporting workflow aligned to ICAO Annex 17.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 15% cost reduction in exchange service operations within 12 weeks measured against baseline","Phase exit: All features deployed to production with signed UAT and ICAO Annex 17 compliance audit passed"],"phase":3},{"epic_id":"EPIC-397AB523","title":"Manage F&B Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"End-to-end capability for planning, onboarding, operating, and optimising food & beverage concessions across airport terminals to maximise passenger satisfaction and non-aeronautical revenue. Sits within Manage Non-Aviation Commercial Services under Manage Airport Core Operation, covering tenant management, menu governance, hygiene compliance, and digital ordering experiences.","business_value":"Increase non-aeronautical revenue per passenger by 15% through optimised F&B tenant mix and dynamic pricing, and improve passenger F&B satisfaction (CSAT) scores by 20% via AI-driven personalisation and faster service.","strategic_rationale":"Per Gartner Top Trends 2025 (AI-Powered Digital Transformation), enterprises using AI report 20-30% productivity gains and 15% cost reduction on average — enabling the Airport Authority to modernise F&B operations with generative AI, agentic workflows, and vector-based recommendation engines.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 access-control and screening requirements could trigger regulatory sanctions and operational shutdowns","Underperforming AI personalisation or integration delays with POS/IAM systems may erode projected 15% revenue uplift and passenger CSAT targets"],"estimated_sprints":6,"features":[{"title":"F&B Tenant & Concession Management","description":"Digital onboarding, contract management, and performance tracking for F&B concessionaires across terminals.","technical_notes":"Leverage Generative AI for contract summarisation and Agentic workflows for automated tenant compliance checks; vector databases to index lease clauses.","user_stories":[{"role":"Commercial Manager","want":"a centralised tenant lifecycle dashboard with AI-assisted contract insights","so_that":"I can accelerate concession onboarding and monitor revenue-share compliance","acceptance_criteria":["All active F&B tenants visible with contract status and KPIs","AI-generated contract summaries available within 30 seconds","Automated alerts triggered 60 days before contract expiry"],"tasks":[{"title":"Design tenant lifecycle data model","description":"Define entities, relationships, and KPIs aligned to commercial governance frameworks.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Implement GenAI contract summariser","description":"Deploy LLM-based summarisation service with vector DB indexing of contract clauses.","estimated_days":8,"assignee_role":"Data Engineer"},{"title":"Build tenant dashboard UI","description":"Develop web dashboard showing tenant status, revenue, and compliance alerts.","estimated_days":6,"assignee_role":"Full-Stack Developer"}]}],"estimated_story_points":8},{"title":"Menu & Pricing Governance","description":"Standardised menu approval workflow with dynamic pricing guardrails for F&B outlets.","technical_notes":"Agentic workflows for menu approval routing; GenAI to benchmark pricing against market data.","user_stories":[{"role":"F&B Operations Lead","want":"an automated menu and price-change approval workflow","so_that":"I can enforce pricing fairness and brand consistency across outlets","acceptance_criteria":["Menu change requests routed to approvers within 1 business day","Price variance vs. benchmark flagged automatically","Audit trail retained for 7 years"],"tasks":[{"title":"Configure agentic approval workflow","description":"Build multi-step approval agent with escalation rules per concession tier.","estimated_days":6,"assignee_role":"Business Analyst"},{"title":"Integrate market pricing benchmarks","description":"Connect external pricing feeds and GenAI comparison engine.","estimated_days":5,"assignee_role":"Data Engineer"}]}],"estimated_story_points":5},{"title":"Hygiene, Safety & Security Compliance","description":"Unified compliance module covering food hygiene audits and ICAO Annex 17 aviation security controls for F&B staff and supplies.","technical_notes":"Agentic workflows for inspection scheduling; AMD MI300X inference for computer-vision hygiene audits; vector DB of incident reports.","user_stories":[{"role":"Security Compliance Officer","want":"automated screening and access-control tracking for F&B staff and deliveries into security restricted areas","so_that":"the airport maintains ICAO Annex 17 compliance and mitigates unlawful interference risks","acceptance_criteria":["100% of F&B staff access to SRA logged and validated","All deliveries screened via approved equipment with audit record","Unlawful interference incidents reported to authority within 24 hours"],"tasks":[{"title":"Integrate SRA access-control system","description":"Connect F&B staff badges to airport IAM and SRA gate readers per NASP.","estimated_days":7,"assignee_role":"Security Analyst"},{"title":"Deploy CV-based hygiene inspection","description":"Run AMD MI300X inference models over outlet CCTV for hygiene and security anomalies.","estimated_days":9,"assignee_role":"ML Engineer"},{"title":"Build 24-hour incident reporting pipeline","description":"Automate unlawful-interference reporting to national authority within mandated SLA.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Digital Ordering & Passenger Experience","description":"Omni-channel F&B ordering with AI personalisation for pre-order, pickup, and gate delivery.","technical_notes":"Generative AI recommendations, vector database for menu similarity search, agentic workflow for order orchestration.","user_stories":[{"role":"Passenger Experience Manager","want":"an AI-personalised F&B ordering app integrated with flight data","so_that":"passengers receive timely, relevant offers improving spend and satisfaction","acceptance_criteria":["Recommendations personalised using flight context and preferences","Order-to-delivery time under 15 minutes at gate","App CSAT score ≥ 4.3/5 post-launch"],"tasks":[{"title":"Develop GenAI recommendation engine","description":"Implement embedding-based recommender on vector DB with flight context features.","estimated_days":10,"assignee_role":"ML Engineer"},{"title":"Build mobile ordering front-end","description":"Release iOS/Android ordering flow integrated with payment and loyalty.","estimated_days":9,"assignee_role":"Mobile Developer"},{"title":"Orchestrate gate-delivery agent","description":"Agentic workflow routing orders to outlets and runners based on flight status.","estimated_days":6,"assignee_role":"Solutions Architect"}]}],"estimated_story_points":13},{"title":"F&B Revenue & Performance Analytics","description":"Real-time analytics on sales, footfall, and concession performance to drive tenant-mix optimisation.","technical_notes":"Vector databases for semantic search over transaction and review data; GenAI narrative insights.","user_stories":[{"role":"Commercial Analyst","want":"real-time F&B revenue and KPI dashboards with AI-generated insights","so_that":"I can recommend tenant-mix and pricing adjustments to maximise revenue","acceptance_criteria":["Dashboards refresh within 5 minutes of POS transactions","AI narrative highlights top 3 performance drivers weekly","Revenue per passenger KPI tracked per terminal and outlet"],"tasks":[{"title":"Build POS data ingestion pipeline","description":"Stream transactions from outlet POS to central data lake with quality checks.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Develop GenAI insight generator","description":"Weekly narrative insights over sales and CSAT data using LLM with RAG.","estimated_days":5,"assignee_role":"ML Engineer"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 15% uplift in F&B revenue per enplaned passenger within 2 quarters of go-live","Phase exit: all F&B outlets onboarded to unified digital platform with UAT sign-off and ICAO Annex 17 compliance attestation"],"phase":3},{"epic_id":"EPIC-CA89BC20","title":"Manage General Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"Manage General Services capability oversees non-aviation commercial services within airport core operations, ensuring efficient management of retail, food & beverage, advertising, and ancillary commercial concessions. This subdomain enables the airport authority to maximize non-aeronautical revenue while maintaining compliance with aviation security and operational standards.","business_value":"Increase non-aeronautical revenue by 20% through optimized commercial service management, and improve passenger satisfaction scores by 15% through enhanced retail and service experiences.","strategic_rationale":"Per Gartner Top Trends 2025, enterprises adopting AI-Powered Digital Transformation report 20-30% productivity gains and 15% cost reduction on average, providing strong justification for AI-enabled commercial service management.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 security screening and access control requirements may delay go-live and incur regulatory penalties","AI model accuracy and data quality risks could undermine demand forecasting and revenue optimization outcomes"],"estimated_sprints":6,"features":[{"title":"Manage Retail Concessions","description":"Centralized platform to manage retail tenant lifecycle, lease agreements, performance, and compliance across airport terminals.","technical_notes":"Leverage Generative AI for contract analysis, Vector databases for tenant performance benchmarking, and Agentic workflows for lease renewal automation.","user_stories":[{"role":"Commercial Services Manager","want":"a unified dashboard to monitor retail tenant performance and compliance","so_that":"I can maximize concession revenue and ensure regulatory adherence","acceptance_criteria":["Dashboard displays real-time sales, footfall, and compliance KPIs per tenant","Automated alerts for lease expirations and compliance breaches","Integration with security access control for restricted-area tenants"],"tasks":[{"title":"Design retail tenant data model","description":"Define entities, relationships, and KPI structures for retail concession management aligned with airport commercial frameworks.","estimated_days":4,"assignee_role":"Solutions Architect"},{"title":"Build tenant performance dashboard","description":"Develop interactive dashboard surfacing sales, footfall, and compliance metrics with drill-down capabilities.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Integrate with security access systems","description":"Connect tenant management module with NASP-aligned access control to enforce security restricted area rules.","estimated_days":5,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Manage Food & Beverage Services","description":"Oversee F&B concessionaires, menu compliance, hygiene audits, and revenue performance across airport terminals.","technical_notes":"Use Agentic workflows for automated hygiene inspection scheduling and Generative AI for menu compliance review.","user_stories":[{"role":"F&B Operations Lead","want":"automated hygiene inspection scheduling and reporting","so_that":"I can ensure all F&B outlets remain compliant with health and safety standards","acceptance_criteria":["Inspection schedules auto-generated based on risk profile","Inspection findings logged and tracked to closure","Non-compliance escalations routed within 24 hours"],"tasks":[{"title":"Configure inspection workflow engine","description":"Set up agentic workflow rules for risk-based hygiene inspection scheduling and escalation paths.","estimated_days":6,"assignee_role":"Process Engineer"},{"title":"Develop inspection mobile app","description":"Build mobile-friendly inspection capture tool for auditors with offline support and photo evidence.","estimated_days":8,"assignee_role":"Mobile Developer"}]}],"estimated_story_points":8},{"title":"Manage Advertising & Sponsorship","description":"Manage advertising inventory, digital signage, sponsorship deals, and revenue allocation across the airport estate.","technical_notes":"Leverage Vector databases for ad performance analytics and Generative AI for creative content compliance review.","user_stories":[{"role":"Advertising Manager","want":"an inventory management system for digital and static advertising spaces","so_that":"I can optimize occupancy rates and maximize ad revenue","acceptance_criteria":["All ad inventory catalogued with location, dimensions, and pricing","Real-time availability and booking workflow available","Revenue and occupancy KPIs reported monthly"],"tasks":[{"title":"Catalogue ad inventory locations","description":"Conduct site survey and catalogue all advertising assets with metadata for management platform.","estimated_days":5,"assignee_role":"Business Analyst"},{"title":"Implement booking and billing module","description":"Develop end-to-end advertising booking, contract, and billing workflow integrated with finance systems.","estimated_days":9,"assignee_role":"Software Engineer"}]}],"estimated_story_points":13},{"title":"Manage Ancillary Commercial Services","description":"Coordinate lounges, currency exchange, parking, and other ancillary services to enhance passenger experience and revenue.","technical_notes":"Use Agentic workflows for service orchestration and AMD MI300X inference for real-time demand forecasting.","user_stories":[{"role":"Passenger Experience Manager","want":"demand forecasting for ancillary services","so_that":"I can align staffing and inventory with passenger demand patterns","acceptance_criteria":["Forecasts generated daily with 90% accuracy","Forecast outputs integrated with workforce planning","Alerts triggered for demand surges"],"tasks":[{"title":"Build demand forecasting model","description":"Develop ML forecasting model leveraging AMD MI300X inference for ancillary service demand prediction.","estimated_days":10,"assignee_role":"Data Scientist"},{"title":"Integrate forecasts with workforce planning","description":"Connect forecast outputs to workforce management system for automated staffing recommendations.","estimated_days":6,"assignee_role":"Integration Engineer"}]}],"estimated_story_points":13}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 20% increase in non-aeronautical revenue within 12 weeks of go-live","Phase exit: All commercial service modules deployed, integrated with security systems, and validated through UAT sign-off"],"phase":3},{"epic_id":"EPIC-C544871C","title":"Manage Leisure Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"Capability to manage non-aviation leisure services (lounges, entertainment, recreation, spa, and wellness offerings) within airport terminals to enhance passenger experience and generate ancillary revenue. Operates under Manage Non-Aviation Commercial Services subdomain, integrating retail, hospitality, and experiential services across landside and airside zones.","business_value":"Increase non-aeronautical revenue per passenger by 15% through curated leisure offerings, and improve passenger satisfaction (NPS) by 20 points via AI-personalised leisure experiences.","strategic_rationale":"Aligned with Gartner Top Trends 2025 – AI-Powered Digital Transformation: enterprises using AI report 20-30% productivity gains and 15% cost reduction on average, enabling data-driven personalisation of leisure services and operational efficiency.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Non-compliance with ICAO Annex 17 screening and access control requirements could result in regulatory sanctions and operational shutdown of leisure zones.","AI personalisation models may underperform without sufficient passenger preference data, delaying expected productivity and revenue gains."],"estimated_sprints":6,"features":[{"title":"Lounge & Premium Experience Management","description":"Manage reservations, access control, and personalised services across airport lounges and premium leisure zones.","technical_notes":"Generative AI concierge agents, Agentic workflows for booking orchestration, Vector databases for passenger preference embeddings, AMD MI300X inference for real-time recommendations.","user_stories":[{"role":"Lounge Operations Manager","want":"an AI-powered lounge booking and access platform","so_that":"premium passengers receive frictionless, personalised leisure access while security compliance is maintained","acceptance_criteria":["Passengers can book lounge slots via mobile with biometric entry","Access control enforces security-restricted area rules per ICAO Annex 17","AI concierge recommends services with <2s latency"],"tasks":[{"title":"Design lounge access control integration","description":"Define interface between lounge booking system and airport security restricted area access control per ICAO Annex 17.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Deploy GenAI concierge agent","description":"Build and deploy generative AI concierge with vector-based passenger preference retrieval on AMD MI300X inference.","estimated_days":8,"assignee_role":"AI Engineer"},{"title":"Conduct security quality control inspection","description":"Perform quality control inspection of lounge access measures and document findings for NASP compliance.","estimated_days":3,"assignee_role":"Security Analyst"}]}],"estimated_story_points":13},{"title":"Entertainment & Recreation Services","description":"Curate and operate entertainment, gaming, cinema, and recreation facilities for transit and dwell-time passengers.","technical_notes":"Agentic workflows for dynamic scheduling, Generative AI content personalisation, Vector databases for passenger segment clustering.","user_stories":[{"role":"Commercial Services Manager","want":"a dynamic entertainment scheduling and personalisation engine","so_that":"recreational offerings match passenger dwell-time profiles and maximise engagement revenue","acceptance_criteria":["Schedules adapt in real time based on flight delays and passenger mix","Personalised recommendations delivered via airport app","All venues maintain screening compliance for entry"],"tasks":[{"title":"Build agentic scheduling workflow","description":"Develop agentic workflow to orchestrate entertainment schedule based on flight and passenger data feeds.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Integrate passenger screening checkpoints","description":"Ensure all airside entertainment zones enforce screening of all passengers and carry-on baggage using approved equipment.","estimated_days":4,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Spa, Wellness & Health Services","description":"Deliver spa, wellness, fitness, and quick-service health offerings integrated with airport loyalty and booking systems.","technical_notes":"Vector databases for wellness preference matching, Generative AI for treatment recommendations, Agentic booking workflows.","user_stories":[{"role":"Wellness Concessions Lead","want":"a unified wellness booking and incident reporting platform","so_that":"passengers access wellness services safely and any incidents are reported within regulatory timelines","acceptance_criteria":["Unified booking across all wellness concessions","Incident reporting workflow triggers notification within 24 hours","Loyalty integration credits wellness spend automatically"],"tasks":[{"title":"Implement incident reporting workflow","description":"Configure workflow to report all acts of unlawful interference within 24 hours in line with ICAO Annex 17.","estimated_days":4,"assignee_role":"Compliance Analyst"},{"title":"Deploy wellness recommendation engine","description":"Implement vector-database-backed recommendation service for personalised spa and wellness treatments.","estimated_days":6,"assignee_role":"AI Engineer"},{"title":"Integrate NASP controls","description":"Align wellness service operations with the national aviation security programme (NASP) governance controls.","estimated_days":3,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Achieve 15% uplift in leisure-service revenue per enplaned passenger within 12 weeks of go-live","Phase exit: all leisure service touchpoints integrated with central CRM and security-cleared prior to production cutover"],"phase":3},{"epic_id":"EPIC-DFE856EA","title":"Manage Lounge Services","subdomain_group":"Manage Non-Aviation Commercial Services","description":"Capability to operate, monetize, and govern airport passenger lounges as part of non-aviation commercial services, integrating access control, hospitality, and digital experiences. Scope covers lounge access management, occupancy optimization, partner concessionaire operations, and compliance with aviation security within restricted areas.","business_value":"Increase non-aeronautical revenue per passenger by 15% through optimized lounge utilization and premium service upsell; improve passenger satisfaction (NPS) by 20 points via AI-personalized lounge experiences.","strategic_rationale":"Aligned with Gartner Top Trends 2025 (AI-Powered Digital Transformation): enterprises adopting AI report 20-30% productivity gains and 15% cost reduction on average, enabling the Airport Authority to modernize lounge operations with generative AI and agentic workflows.","governance_reference":"ICAO Annex 17 (Aviation Security) — ICAO","trend_alignment":"AI-Powered Digital Transformation","risk_register":["Integration complexity with airline DCS, loyalty, and partner entitlement systems may delay access control rollout","Non-compliance with ICAO Annex 17 security restricted area controls could result in regulatory sanctions and reputational impact"],"estimated_sprints":6,"features":[{"title":"Lounge Access & Eligibility Management","description":"Digital platform to validate lounge eligibility, manage entitlements, and control passenger entry into lounges within security restricted areas.","technical_notes":"Leverage Generative AI for personalized entitlement messaging, Agentic workflows for dynamic access validation, and Vector databases for loyalty profile matching.","user_stories":[{"role":"Lounge Operations Manager","want":"an automated eligibility and access control system integrated with boarding passes and loyalty programs","so_that":"only authorized passengers enter lounges and revenue leakage is eliminated","acceptance_criteria":["System validates boarding pass, loyalty tier, and partner entitlements in <2 seconds","Access control integrates with airport security restricted area policies","Audit log captures every entry attempt with timestamp and decision"],"tasks":[{"title":"Design lounge access control architecture","description":"Define integration with DCS, loyalty, and access control systems aligned to ICAO Annex 17 restricted area rules.","estimated_days":5,"assignee_role":"Solutions Architect"},{"title":"Implement eligibility validation API","description":"Build real-time entitlement validation service combining airline, card, and partner rules.","estimated_days":8,"assignee_role":"Integration Engineer"},{"title":"Deploy access gate hardware integration","description":"Connect e-gates and QR scanners with the lounge access platform and security restricted area controls.","estimated_days":6,"assignee_role":"Security Analyst"}]}],"estimated_story_points":8},{"title":"Lounge Occupancy & Experience Optimization","description":"AI-driven capacity management and personalized passenger experience platform for lounge environments.","technical_notes":"Uses AMD MI300X inference for real-time occupancy forecasting, Generative AI for concierge chat, and Vector databases for guest preference retrieval.","user_stories":[{"role":"Commercial Services Analyst","want":"real-time occupancy dashboards and AI-driven demand forecasting","so_that":"lounge capacity, staffing, and F&B provisioning are optimized against passenger flows","acceptance_criteria":["Occupancy data refreshed every 60 seconds across all lounges","Forecast accuracy ≥90% for 4-hour ahead demand","Dashboard exposes KPIs: utilization %, dwell time, revenue per visit"],"tasks":[{"title":"Build occupancy data pipeline","description":"Ingest sensor, gate, and POS data into an analytics lakehouse for near real-time consumption.","estimated_days":7,"assignee_role":"Data Engineer"},{"title":"Train demand forecasting model","description":"Develop and deploy ML forecasting on AMD MI300X inference with vector-based passenger profile features.","estimated_days":9,"assignee_role":"Data Scientist"},{"title":"Deliver operations dashboard","description":"Publish Power BI/Tableau dashboards visualizing utilization, dwell time, and revenue KPIs.","estimated_days":4,"assignee_role":"BI Developer"}]}],"estimated_story_points":13},{"title":"Lounge Security & Compliance Assurance","description":"Compliance and quality control workflows ensuring lounge operations align with ICAO Annex 17 and NASP mandates.","technical_notes":"Agentic workflows orchestrate inspections, incident reporting, and evidence capture; Generative AI drafts regulator-ready reports.","user_stories":[{"role":"Aviation Security Officer","want":"automated quality control inspections and unlawful interference reporting within lounges","so_that":"the airport remains compliant with ICAO Annex 17 and NASP obligations","acceptance_criteria":["Quality control inspection checklists executed on schedule with digital evidence","Unlawful interference events trigger reporting workflow within 24 hours","All findings tracked to closure with auditable trail"],"tasks":[{"title":"Configure NASP-aligned inspection workflows","description":"Model inspection templates and escalation paths aligned to the national aviation security programme.","estimated_days":5,"assignee_role":"Compliance Analyst"},{"title":"Implement 24-hour incident reporting service","description":"Build automated unlawful interference notification pipeline to regulators and executives.","estimated_days":6,"assignee_role":"Security Analyst"},{"title":"Integrate screening equipment telemetry","description":"Stream approved screening equipment status and events into the compliance monitoring platform.","estimated_days":5,"assignee_role":"Integration Engineer"}]}],"estimated_story_points":8}],"acceptance_criteria":["Implement national aviation security programme (NASP)","Screen all passengers and carry-on baggage using approved equipment","Maintain access control to security restricted areas","Conduct quality control inspections of security measures","Report all acts of unlawful interference within 24 hours","Lounge occupancy utilization measured and optimized to ≥75% during peak hours","Phase exit: all lounge access, screening, and reporting workflows deployed to production with signed-off UAT and security audit"],"phase":3}],"objectives":["Improved asset availability and reduced unplanned downtime through predictive planning; enhanced capital investment decisions aligned to operational risk and passenger experience outcomes.","Increase non-